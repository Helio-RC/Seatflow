<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
        xmlns:fic="using:FluentIcons.Avalonia"
        xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="A_Pair.Presentation.Avalonia.Views.MainWindow"
        x:DataType="vm:MainShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="A_Pair — 安排" Width="1200" Height="800"
        MinWidth="550" MinHeight="600">

    <Design.DataContext>
        <vm:MainShellViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- 侧边栏 -->
        <Border DockPanel.Dock="Left" Width="{Binding SidebarWidth}" Background="#F0F0F0"
                ClipToBounds="True">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.25"
                                      Easing="CubicEaseInOut" />
                </Transitions>
            </Border.Transitions>
            <DockPanel>
                <!-- 标题：居中，固定位置，收窄时右侧被裁切 -->
                <Border DockPanel.Dock="Top" Height="44">
                    <TextBlock Text="A_Pair" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- 底部：设置 + 关于 -->
                <Border DockPanel.Dock="Bottom" Padding="10,0" Margin="0,6,0,10">
                    <Panel>
                        <!-- 展开 -->
                        <StackPanel Spacing="8" IsVisible="{Binding IsSidebarExpanded}">
                            <Separator Margin="0,0,0,4"/>
                            <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Settings}" FontSize="20" Height="20"/>
                                    <TextBlock Text="设置" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="About"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Info}" FontSize="20" Height="20"/>
                                    <TextBlock Text="关于" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <!-- 折叠 -->
                        <StackPanel Spacing="8" IsVisible="{Binding !IsSidebarExpanded}"
                                    HorizontalAlignment="Center">
                            <Button Height="44" Width="44" Padding="0" ToolTip.Tip="设置"
                                    Command="{Binding NavigateCommand}" CommandParameter="Settings">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Settings}" FontSize="24" Height="24"/>
                            </Button>
                            <Button Height="44" Width="44" Padding="0" ToolTip.Tip="关于"
                                    Command="{Binding NavigateCommand}" CommandParameter="About">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Info}" FontSize="24" Height="24"/>
                            </Button>
                        </StackPanel>
                    </Panel>
                </Border>

                <!-- 导航区：中部填充 -->
                <Panel>
                    <!-- 展开状态 -->
                    <StackPanel Margin="10,0,10,4" Spacing="8" IsVisible="{Binding IsSidebarExpanded}">
                        <Button Height="44" Command="{Binding ToggleSidebarCommand}"
                                HorizontalContentAlignment="Right"
                                ToolTip.Tip="折叠侧边栏">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftContract}" FontSize="20" Height="20"/>
                                <TextBlock Text="折叠边栏" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="DataManagement"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.DataUsage}" FontSize="20" Height="20"/>
                                <TextBlock Text="数据管理" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="VenueConfiguration"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Building}" FontSize="20" Height="20"/>
                                <TextBlock Text="会场配置" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="StrategyConfiguration"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Options}" FontSize="20" Height="20"/>
                                <TextBlock Text="策略配置" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="SeatingArrangement"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Grid}" FontSize="20" Height="20"/>
                                <TextBlock Text="座位安排" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="SnapshotHistory"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.History}" FontSize="20" Height="20"/>
                                <TextBlock Text="历史快照" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="PluginManagement"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PuzzlePiece}" FontSize="20" Height="20"/>
                                <TextBlock Text="插件管理" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 折叠状态 -->
                    <StackPanel Spacing="8" IsVisible="{Binding !IsSidebarExpanded}"
                                HorizontalAlignment="Center">
                        <Button Height="44" Width="44" Padding="0" HorizontalAlignment="Center"
                                Command="{Binding ToggleSidebarCommand}"
                                ToolTip.Tip="展开侧边栏">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftExpand}" FontSize="24" Height="24"/>
                        </Button>

                        <Button Height="44" Width="44" Padding="0" ToolTip.Tip="数据管理"
                                Command="{Binding NavigateCommand}" CommandParameter="DataManagement">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.DataUsage}" FontSize="24" Height="24"/>
                        </Button>
                        <Button Height="44" Width="44" Padding="0" ToolTip.Tip="会场配置"
                                Command="{Binding NavigateCommand}" CommandParameter="VenueConfiguration">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Building}" FontSize="24" Height="24"/>
                        </Button>
                        <Button Height="44" Width="44" Padding="0" ToolTip.Tip="策略配置"
                                Command="{Binding NavigateCommand}" CommandParameter="StrategyConfiguration">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Options}" FontSize="24" Height="24"/>
                        </Button>
                        <Button Height="44" Width="44" Padding="0" ToolTip.Tip="座位安排"
                                Command="{Binding NavigateCommand}" CommandParameter="SeatingArrangement">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Grid}" FontSize="24" Height="24"/>
                        </Button>
                        <Button Height="44" Width="44" Padding="0" ToolTip.Tip="历史快照"
                                Command="{Binding NavigateCommand}" CommandParameter="SnapshotHistory">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.History}" FontSize="24" Height="24"/>
                        </Button>
                        <Button Height="44" Width="44" Padding="0" ToolTip.Tip="插件管理"
                                Command="{Binding NavigateCommand}" CommandParameter="PluginManagement">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PuzzlePiece}" FontSize="24" Height="24"/>
                        </Button>
                    </StackPanel>
                </Panel>
            </DockPanel>
        </Border>

        <!-- 内容区域 -->
        <ContentControl Content="{Binding CurrentViewModel}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </DockPanel>
</Window>
