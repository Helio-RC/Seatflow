<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="A_Pair.Presentation.Avalonia.Views.MainWindow"
        x:DataType="vm:MainShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="A_Pair — 座位安排系统" Width="1200" Height="800"
        MinWidth="550" MinHeight="600">

    <Design.DataContext>
        <vm:MainShellViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- 侧边栏：宽度根据 IsSidebarExpanded 动态变化 -->
        <Border DockPanel.Dock="Left" Width="{Binding SidebarWidth}" Background="#F0F0F0">
            <Grid>
                <!-- 展开状态：完整文字按钮 -->
                <StackPanel Margin="10" Spacing="6" IsVisible="{Binding IsSidebarExpanded}">
                    <TextBlock Text="A_Pair" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Button Content="数据管理"
                            Command="{Binding NavigateCommand}" CommandParameter="DataManagement"/>
                    <Button Content="会场配置"
                            Command="{Binding NavigateCommand}" CommandParameter="VenueConfiguration"/>
                    <Button Content="策略配置"
                            Command="{Binding NavigateCommand}" CommandParameter="StrategyConfiguration"/>
                    <Button Content="座位安排"
                            Command="{Binding NavigateCommand}" CommandParameter="SeatingArrangement"/>
                    <Button Content="历史快照"
                            Command="{Binding NavigateCommand}" CommandParameter="SnapshotHistory"/>
                    <Button Content="插件管理"
                            Command="{Binding NavigateCommand}" CommandParameter="PluginManagement"/>

                    <!-- 次要页面：紧邻功能导航下方 -->
                    <Separator Margin="0,4"/>
                    <Button Content="设置"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
                    <Button Content="关于"
                            Command="{Binding NavigateCommand}" CommandParameter="About"/>

                    <!-- 折叠按钮在最底部 -->
                    <Separator Margin="0,4"/>
                    <Button Content="« 折叠"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip.Tip="折叠侧边栏"/>
                </StackPanel>

            <!-- 折叠状态：单字按钮 + ToolTip -->
            <StackPanel Margin="4" Spacing="4" IsVisible="{Binding !IsSidebarExpanded}">
                <Button Content="☰" FontSize="14" Padding="4"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip.Tip="展开侧边栏" Margin="0,0,0,6"/>

                <Button Content="数" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="DataManagement"
                        ToolTip.Tip="数据管理"/>
                <Button Content="场" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="VenueConfiguration"
                        ToolTip.Tip="会场配置"/>
                <Button Content="策" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="StrategyConfiguration"
                        ToolTip.Tip="策略配置"/>
                <Button Content="座" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="SeatingArrangement"
                        ToolTip.Tip="座位安排"/>
                <Button Content="史" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="SnapshotHistory"
                        ToolTip.Tip="历史快照"/>
                <Button Content="插" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="PluginManagement"
                        ToolTip.Tip="插件管理"/>
                <Button Content="设" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="Settings"
                        ToolTip.Tip="设置"/>
                <Button Content="关" FontSize="14" Padding="4"
                        Command="{Binding NavigateCommand}" CommandParameter="About"
                        ToolTip.Tip="关于"/>
            </StackPanel>
            </Grid>
        </Border>

        <!-- 内容区域 -->
        <ContentControl Content="{Binding CurrentViewModel}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </DockPanel>
</Window>
