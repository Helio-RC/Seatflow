<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
        xmlns:conv="using:A_Pair.Presentation.Avalonia.Converters"
        xmlns:lang="using:A_Pair.Presentation.Avalonia.Lang"
        xmlns:fic="using:FluentIcons.Avalonia"
        xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="A_Pair.Presentation.Avalonia.Views.MainWindow"
        x:DataType="vm:MainShellViewModel"
        Icon="/Assets/icon_with_background.ico"
        Title="{x:Static lang:Resources.App_Title}" Width="1200" Height="800"
        MinWidth="550" MinHeight="600"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="32"
        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">

  <Design.DataContext>
    <vm:MainShellViewModel/>
  </Design.DataContext>

  <Grid>
    <DockPanel Margin="0,32,0,0">
    <!-- 侧边栏 -->
    <Border DockPanel.Dock="Left" Width="{Binding SidebarWidth}" Background="{DynamicResource SidebarBackgroundBrush}"
            ClipToBounds="True" KeyboardNavigation.TabNavigation="Cycle">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.25"
                            Easing="CubicEaseInOut" />
        </Transitions>
      </Border.Transitions>
      <DockPanel>
        <!-- 标题 -->
        <Border DockPanel.Dock="Top" Height="44">
          <Panel>
            <TextBlock Text="A_Pair" Classes="heading"
                       Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.TrueToVisible}}"
                       IsHitTestVisible="{Binding IsSidebarExpanded}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <TextBlock Text="{x:Static lang:Resources.Nav_AppShort}" Classes="heading"
                       Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.FalseToVisible}}"
                       IsHitTestVisible="{Binding IsSidebarCollapsed}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Panel>
        </Border>

        <!-- 底部：设置 + 关于 -->
        <Border DockPanel.Dock="Bottom" Margin="0,0,0,10">
          <Panel>
            <StackPanel Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.TrueToVisible}}" IsHitTestVisible="{Binding IsSidebarExpanded}"
                        Margin="10,0,10,0" Spacing="8">
              <StackPanel.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut" />
                </Transitions>
              </StackPanel.Transitions>
              <Separator Margin="0,0,0,0"/>
              <Button x:Name="SettingsButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="Settings" AutomationProperties.Name="{x:Static lang:Resources.Nav_Settings}"
                      HorizontalContentAlignment="Center" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Settings}" FontSize="20" Height="20"/>
                  <TextBlock Text="{x:Static lang:Resources.Nav_Settings}" Classes="bodyLarge" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="About" AutomationProperties.Name="{x:Static lang:Resources.Nav_About}"
                      HorizontalContentAlignment="Center" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Info}" FontSize="20" Height="20"/>
                  <TextBlock Text="{x:Static lang:Resources.Nav_About}" Classes="bodyLarge" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
            <StackPanel Spacing="8" Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.FalseToVisible}}"
                        IsHitTestVisible="{Binding IsSidebarCollapsed}" HorizontalAlignment="Center">
              <StackPanel.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut" />
                </Transitions>
              </StackPanel.Transitions>
              <Separator Margin="0,0,0,0"/>
              <Button Height="44" Width="44" Padding="0"
                      AutomationProperties.Name="{x:Static lang:Resources.Nav_Settings}"
                      ToolTip.Tip="{x:Static lang:Resources.Nav_Settings}"
                      Command="{Binding NavigateCommand}" CommandParameter="Settings">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Settings}" FontSize="24" Height="24"/>
              </Button>
              <Button Height="44" Width="44" Padding="0" HorizontalAlignment="Center"
                      AutomationProperties.Name="{x:Static lang:Resources.Nav_About}"
                      ToolTip.Tip="{x:Static lang:Resources.Nav_About}"
                      Command="{Binding NavigateCommand}" CommandParameter="About">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Info}" FontSize="24" Height="24"/>
              </Button>
            </StackPanel>
          </Panel>
        </Border>

        <!-- 导航区：中部填充 -->
        <Panel>
          <!-- 展开状态 -->
          <StackPanel Margin="10,0,10,4" Spacing="8" Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.TrueToVisible}}"
                      IsHitTestVisible="{Binding IsSidebarExpanded}" HorizontalAlignment="Stretch">
            <StackPanel.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut" />
              </Transitions>
            </StackPanel.Transitions>
            <Button x:Name="ToggleSidebarButton" Height="44" Command="{Binding ToggleSidebarCommand}" AutomationProperties.Name="{x:Static lang:Resources.Nav_ToggleSidebar}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_CollapseSidebar}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftContract}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_CollapseSidebar}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="HomeButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="Home" AutomationProperties.Name="{x:Static lang:Resources.Nav_Home}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Home}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_Home}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="MemberButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="MemberManagement" AutomationProperties.Name="{x:Static lang:Resources.Nav_MemberManagement}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.DataUsage}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_MemberManagement}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="VenueButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="VenueConfiguration" AutomationProperties.Name="{x:Static lang:Resources.Nav_VenueConfig}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Building}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_VenueConfig}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="FreeformManagement" AutomationProperties.Name="{x:Static lang:Resources.Nav_Freeform}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowMove}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_Freeform}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="StrategyButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="StrategyConfiguration" AutomationProperties.Name="{x:Static lang:Resources.Nav_StrategyConfig}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Options}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_StrategyConfig}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="SeatingButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="SeatingArrangement" AutomationProperties.Name="{x:Static lang:Resources.Nav_Seating}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Grid}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_Seating}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="SnapshotButton" Height="44" Command="{Binding NavigateCommand}" CommandParameter="SnapshotHistory" AutomationProperties.Name="{x:Static lang:Resources.Nav_SnapshotHistory}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.History}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_SnapshotHistory}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Height="44" Command="{Binding NavigateCommand}" CommandParameter="PluginManagement" AutomationProperties.Name="{x:Static lang:Resources.Nav_PluginManagement}"
                    Opacity="{Binding PluginManagementOpacity}"
                    ToolTip.Tip="{Binding PluginManagementDisabledTip}"
                    HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PuzzlePiece}" FontSize="24" Height="24"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_PluginManagement}" Classes="bodyLarge" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- 折叠状态 -->
          <StackPanel Spacing="8" Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.FalseToVisible}}"
                      IsHitTestVisible="{Binding IsSidebarCollapsed}" HorizontalAlignment="Center">
            <StackPanel.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut" />
              </Transitions>
            </StackPanel.Transitions>
            <Button Height="44" Width="44" Padding="0" HorizontalAlignment="Center"
                    Command="{Binding ToggleSidebarCommand}"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_ToggleSidebar}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_ExpandSidebar}">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftExpand}" FontSize="24" Height="24"/>
            </Button>

            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_Home}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_Home}"
                    Command="{Binding NavigateCommand}" CommandParameter="Home">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Home}" FontSize="24" Height="24"/>
            </Button>

            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_MemberManagement}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_MemberManagement}"
                    Command="{Binding NavigateCommand}" CommandParameter="MemberManagement">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.DataUsage}" FontSize="24" Height="24"/>
            </Button>
            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_VenueConfig}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_VenueConfig}"
                    Command="{Binding NavigateCommand}" CommandParameter="VenueConfiguration">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Building}" FontSize="24" Height="24"/>
            </Button>
            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_Freeform}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_Freeform}"
                    Command="{Binding NavigateCommand}" CommandParameter="FreeformManagement">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowMove}" FontSize="24" Height="24"/>
            </Button>
            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_StrategyConfig}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_StrategyConfig}"
                    Command="{Binding NavigateCommand}" CommandParameter="StrategyConfiguration">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Options}" FontSize="24" Height="24"/>
            </Button>
            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_Seating}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_Seating}"
                    Command="{Binding NavigateCommand}" CommandParameter="SeatingArrangement">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Grid}" FontSize="24" Height="24"/>
            </Button>
            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_SnapshotHistory}"
                    ToolTip.Tip="{x:Static lang:Resources.Nav_SnapshotHistory}"
                    Command="{Binding NavigateCommand}" CommandParameter="SnapshotHistory">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.History}" FontSize="24" Height="24"/>
            </Button>
            <Button Height="44" Width="44" Padding="0"
                    AutomationProperties.Name="{x:Static lang:Resources.Nav_PluginManagement}"
                    Opacity="{Binding PluginManagementOpacity}"
                    ToolTip.Tip="{Binding PluginManagementDisabledTip}"
                    Command="{Binding NavigateCommand}" CommandParameter="PluginManagement">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PuzzlePiece}" FontSize="24" Height="24"/>
            </Button>
          </StackPanel>
        </Panel>
      </DockPanel>
    </Border>

    <!-- 内容区域 -->
    <Grid>
      <ContentControl x:Name="PageHost" Content="{Binding CurrentViewModel}"
                      Opacity="{Binding PageOpacity}"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <ContentControl.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.35" Easing="CubicEaseInOut" />
          </Transitions>
        </ContentControl.Transitions>
      </ContentControl>

    </Grid>
  </DockPanel>

    <!-- 引导遮罩：与主页面同级 Grid 层，非 Popup -->
    <Border x:Name="GuideMaskOverlay"
            IsVisible="False"
            IsHitTestVisible="False"
            Background="#80000000">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Border.Transitions>
    </Border>

    <!-- 目标高亮边框：与主页面同级 -->
    <Border x:Name="GuideTargetHighlight"
            IsVisible="False"
            IsHitTestVisible="False"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            BorderBrush="{DynamicResource SystemAccentColor}"
            BorderThickness="3"
            CornerRadius="4"
            Background="Transparent" />

    <!-- 引导卡片：与主页面同级，非 Popup -->
    <Border x:Name="GuideCardOverlay"
            IsVisible="False"
            MinWidth="280"
            MaxWidth="420"
            Padding="18"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{DynamicResource SurfaceCardBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}"
            BorderThickness="1"
            BoxShadow="{DynamicResource CardShadowLarge}"
            CornerRadius="8"
            Focusable="True">
      <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock x:Name="GuideCardTitle"
                     Classes="bodyLarge" FontWeight="SemiBold"
                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                     TextWrapping="Wrap" />
          <Button x:Name="GuideCardCloseButton"
                  Grid.Column="1" Width="28" Height="28"
                  Margin="12,-4,-8,0" Padding="0"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  ToolTip.Tip="{x:Static lang:Resources.Guide_Close}"
                 >
            <PathIcon Width="13" Height="13"
                      Data="M18.3,5.71L12,12L18.3,18.29L16.89,19.7L10.59,13.41L4.29,19.71L2.88,18.3L9.17,12L2.88,5.7L4.29,4.29L10.59,10.59L16.89,4.29L18.3,5.71Z" />
          </Button>
        </Grid>
        <TextBlock x:Name="GuideCardDesc"
                   Grid.Row="1"
                   Classes="body" TextWrapping="Wrap"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   LineHeight="21" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button x:Name="GuideCardPrevButton"
                  Content="{x:Static lang:Resources.Guide_Previous}"
                  />
          <Button x:Name="GuideCardNextButton"
                  Content="{x:Static lang:Resources.Guide_Next}"
                  Classes="accent"
                  />
          <Button x:Name="GuideCardFinishButton"
                  Content="{x:Static lang:Resources.Guide_Finish}"
                  Classes="accent"
                  IsVisible="False"
                  />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
