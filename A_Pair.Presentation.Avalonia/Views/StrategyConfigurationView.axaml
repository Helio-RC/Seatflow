<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             x:Class="A_Pair.Presentation.Avalonia.Views.StrategyConfigurationView"
             x:DataType="vm:StrategyConfigurationViewModel">
  <Grid Margin="8">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
      <TextBlock Text="可用策略" FontWeight="Bold" />
      <DataGrid Items="{Binding Strategies}" SelectedItem="{Binding SelectedStrategy}" AutoGenerateColumns="False">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="60"/>
          <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="80"/>
          <DataGridTextColumn Header="名称" Binding="{Binding Name}" />
          <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120"/>
        </DataGrid.Columns>
      </DataGrid>
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="上移" Command="{Binding MoveUpCommand}" />
        <Button Content="下移" Command="{Binding MoveDownCommand}" />
        <Button Content="配置" Command="{Binding ConfigureCommand}" />
        <Button Content="删除" Command="{Binding RemoveCommand}" />
      </StackPanel>
    </StackPanel>

    <Border Grid.Column="1" Padding="8" BorderBrush="#DDD" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="当前选中策略配置" FontWeight="Bold" />
        <ContentControl Content="{Binding SelectedStrategy.ConfigurationView}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
