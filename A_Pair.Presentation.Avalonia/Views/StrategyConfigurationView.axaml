<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:conv="using:A_Pair.Presentation.Avalonia.Converters"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.StrategyConfigurationView"
             x:DataType="vm:StrategyConfigurationViewModel">

  <Design.DataContext>
    <vm:StrategyConfigurationViewModel />
  </Design.DataContext>

  <Grid x:Name="SidebarGrid" Margin="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" />
      <ColumnDefinition Width="4" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ═══════════ 侧栏：策略列表 ═══════════ -->
    <Border Grid.Column="0" Width="{Binding SidebarListWidth}" Margin="0,0,8,0"
            CornerRadius="6" ClipToBounds="True" HorizontalAlignment="Left"
            Background="{DynamicResource SidebarBackgroundBrush}">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.25" Easing="CubicEaseInOut" />
        </Transitions>
      </Border.Transitions>

      <DockPanel Margin="8">
        <!-- 标题 -->
        <TextBlock DockPanel.Dock="Top" Text="策略列表" Classes="sectionTitle"
                   Margin="0,0,0,8" />

        <!-- 底部操作按钮 -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
          <StackPanel Spacing="4">
            <!-- 展开状态 -->
            <StackPanel Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.TrueToVisible}}"
                        IsHitTestVisible="{Binding IsSidebarExpanded}"
                        Spacing="4">
              <StackPanel.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseInOut" />
                </Transitions>
              </StackPanel.Transitions>
              <Button Command="{Binding MoveUpCommand}"
                      CommandParameter="{Binding SelectedStrategy}"
                      HorizontalContentAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUp}" FontSize="14" />
                  <TextBlock Text="提高优先级" FontSize="12" />
                </StackPanel>
              </Button>
              <Button Command="{Binding MoveDownCommand}"
                      CommandParameter="{Binding SelectedStrategy}"
                      HorizontalContentAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowDown}" FontSize="14" />
                  <TextBlock Text="降低优先级" FontSize="12" />
                </StackPanel>
              </Button>
              <Button Command="{Binding ToggleSidebarCommand}"
                      HorizontalContentAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftContract}" FontSize="14" />
                  <TextBlock Text="收起侧栏" FontSize="12" />
                </StackPanel>
              </Button>
            </StackPanel>

            <!-- 折叠状态 -->
            <StackPanel Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.FalseToVisible}}"
                        IsHitTestVisible="{Binding IsSidebarCollapsed}"
                        Spacing="4" HorizontalAlignment="Center">
              <StackPanel.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseInOut" />
                </Transitions>
              </StackPanel.Transitions>
              <Button Command="{Binding MoveUpCommand}"
                      CommandParameter="{Binding SelectedStrategy}"
                      Width="30" Height="30" Padding="0"
                      ToolTip.Tip="提高优先级" HorizontalAlignment="Center">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUp}" FontSize="14" />
              </Button>
              <Button Command="{Binding MoveDownCommand}"
                      CommandParameter="{Binding SelectedStrategy}"
                      Width="30" Height="30" Padding="0"
                      ToolTip.Tip="降低优先级" HorizontalAlignment="Center">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowDown}" FontSize="14" />
              </Button>
              <Button Command="{Binding ToggleSidebarCommand}"
                      Width="30" Height="30" Padding="0"
                      ToolTip.Tip="展开侧栏" HorizontalAlignment="Center">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftExpand}" FontSize="14" />
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- 策略列表 -->
        <ListBox ItemsSource="{Binding Strategies}"
                 SelectedItem="{Binding SelectedStrategy, Mode=TwoWay}"
                 BorderThickness="0"
                 Background="{DynamicResource SidebarBackgroundBrush}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:StrategyItemViewModel" x:CompileBindings="False">
              <Border Padding="8,6" CornerRadius="4">
                <Grid>
                  <!-- 展开状态：ToggleSwitch + 名称 + 优先级 -->
                  <DockPanel Opacity="{Binding $parent[ListBox].DataContext.IsSidebarExpanded, Converter={x:Static conv:BoolConverters.TrueToVisible}}"
                             IsHitTestVisible="{Binding $parent[ListBox].DataContext.IsSidebarExpanded}">
                    <DockPanel.Transitions>
                      <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                      </Transitions>
                    </DockPanel.Transitions>
                    <ToggleSwitch DockPanel.Dock="Right"
                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                  VerticalAlignment="Center" />
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" FontSize="13" />
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                          <TextBlock.Text>
                            <Binding Path="Priority" StringFormat="优先级: {0}" />
                          </TextBlock.Text>
                        </TextBlock>
                        <Border CornerRadius="2" Padding="4,1"
                                Background="{DynamicResource SystemControlAccentBrush}"
                                IsVisible="{Binding IsBuiltIn, Converter={x:Static conv:BoolConverters.Negate}}">
                          <TextBlock Text="插件" FontSize="9" Foreground="White" />
                        </Border>
                      </StackPanel>
                    </StackPanel>
                  </DockPanel>
                  <!-- 折叠状态：仅名称（单选模式） -->
                  <StackPanel Opacity="{Binding $parent[ListBox].DataContext.IsSidebarExpanded, Converter={x:Static conv:BoolConverters.FalseToVisible}}"
                              IsHitTestVisible="{Binding $parent[ListBox].DataContext.IsSidebarCollapsed}"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Transitions>
                      <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                      </Transitions>
                    </StackPanel.Transitions>
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" FontSize="12"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                      <TextBlock.Text>
                        <Binding Path="Priority" StringFormat="P{0}" />
                      </TextBlock.Text>
                    </TextBlock>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- ═══════════ 分隔条 ═══════════ -->
    <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                  Background="Transparent" />

    <!-- ═══════════ 右侧详情 ═══════════ -->
    <Grid Grid.Column="2">
      <!-- 空状态：未选中策略 -->
      <Border IsVisible="{Binding HasSelection, Converter={x:Static conv:BoolConverters.Negate}}"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Padding="40" CornerRadius="8"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Options}" FontSize="48"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          HorizontalAlignment="Center" />
          <TextBlock Text="请从左侧选择策略" Classes="sectionTitle" HorizontalAlignment="Center" />
          <TextBlock Text="选择一个策略以查看详情和编辑配置" FontSize="12"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- 详情状态 -->
      <ScrollViewer IsVisible="{Binding HasDetail}" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="560">
          <!-- 策略名称 + 来源标签 -->
          <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <StackPanel Spacing="8">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding SelectedDetail.DisplayName}"
                           Classes="pageTitle" VerticalAlignment="Center" />
                <Border DockPanel.Dock="Right" CornerRadius="4" Padding="8,3"
                        Background="{DynamicResource SystemControlAccentBrush}"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding SelectedDetail.Source, StringFormat='来源: {0}'}"
                             FontSize="11" Foreground="White" />
                </Border>
              </DockPanel>
              <TextBlock Text="{Binding SelectedDetail.Description}"
                         Classes="body" TextWrapping="Wrap"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Classes="caption">
                  <TextBlock.Text>
                    <Binding Path="SelectedDetail.Author" StringFormat="作者: {0}" />
                  </TextBlock.Text>
                </TextBlock>
                <TextBlock Classes="caption">
                  <TextBlock.Text>
                    <Binding Path="SelectedDetail.Category" StringFormat="分类: {0}" />
                  </TextBlock.Text>
                </TextBlock>
                <TextBlock Classes="caption">
                  <TextBlock.Text>
                    <Binding Path="SelectedDetail.DefaultPriority" StringFormat="默认优先级: {0}" />
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- 基本配置 -->
          <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <StackPanel Spacing="14">
              <TextBlock Text="基本配置" Classes="sectionTitle" />
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="优先级" FontSize="14"
                           VerticalAlignment="Center" Width="140" />
                <NumericUpDown Value="{Binding EditPriority, Mode=TwoWay}"
                               Minimum="0" Maximum="999" Increment="1"
                               MinWidth="120" HorizontalAlignment="Right" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="启用" FontSize="14"
                           VerticalAlignment="Center" Width="140" />
                <ToggleSwitch IsChecked="{Binding EditIsEnabled, Mode=TwoWay}"
                              HorizontalAlignment="Right" />
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- FrontRowRotation 参数 -->
          <Border IsVisible="{Binding HasFrontRowConfig}"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <StackPanel Spacing="14">
              <TextBlock Text="参数配置：前排轮换" Classes="sectionTitle" />
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="历史权重 (HistoryWeight)"
                           FontSize="14" VerticalAlignment="Center" Width="200" />
                <NumericUpDown Value="{Binding EditHistoryWeight, Mode=TwoWay}"
                               Minimum="0" Maximum="100" Increment="1"
                               MinWidth="120" HorizontalAlignment="Right" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="前排需求加分"
                           FontSize="14" VerticalAlignment="Center" Width="200" />
                <NumericUpDown Value="{Binding EditNeedsFrontRowBonus, Mode=TwoWay}"
                               Minimum="0" Maximum="10000" Increment="100"
                               MinWidth="120" HorizontalAlignment="Right" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="前排行数"
                           FontSize="14" VerticalAlignment="Center" Width="200" />
                <NumericUpDown Value="{Binding EditFrontRowCount, Mode=TwoWay}"
                               Minimum="1" Maximum="10" Increment="1"
                               MinWidth="120" HorizontalAlignment="Right" />
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- DeskMate 参数 -->
          <Border IsVisible="{Binding HasDeskMateConfig}"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <StackPanel Spacing="14">
              <TextBlock Text="参数配置：同桌分组" Classes="sectionTitle" />
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="优先水平相邻"
                           FontSize="14" VerticalAlignment="Center" Width="200" />
                <ToggleSwitch IsChecked="{Binding EditPreferHorizontal, Mode=TwoWay}"
                              HorizontalAlignment="Right" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="允许垂直相邻"
                           FontSize="14" VerticalAlignment="Center" Width="200" />
                <ToggleSwitch IsChecked="{Binding EditAllowVertical, Mode=TwoWay}"
                              HorizontalAlignment="Right" />
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- 保存/重置按钮 -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button Command="{Binding ResetConfigCommand}"
                    HorizontalContentAlignment="Center" Padding="12,6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="16" />
                <TextBlock Text="恢复默认" FontSize="14" />
              </StackPanel>
            </Button>
            <Button Command="{Binding SaveConfigCommand}"
                    HorizontalContentAlignment="Center" Padding="12,6"
                    IsDefault="True">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
                <TextBlock Text="保存配置" FontSize="14" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- 加载遮罩 -->
      <Border IsVisible="{Binding IsLoading}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
          <ProgressBar IsIndeterminate="True" Width="200" />
          <TextBlock Text="处理中..." FontSize="14" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
