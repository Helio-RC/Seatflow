<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lang="using:A_Pair.Presentation.Avalonia.Lang"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:conv="using:A_Pair.Presentation.Avalonia.Converters"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.StrategyConfigurationView"
             x:DataType="vm:StrategyConfigurationViewModel">

  <Design.DataContext>
    <vm:StrategyConfigurationViewModel />
  </Design.DataContext>

  <Grid x:Name="SidebarGrid" Margin="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ═══════════ 侧栏：策略列表 ═══════════ -->
    <Border Grid.Column="0" Margin="0,0,8,0"
            CornerRadius="6" ClipToBounds="True"
            Background="{DynamicResource SidebarBackgroundBrush}">

      <DockPanel Margin="8">
        <!-- 标题 -->
        <TextBlock DockPanel.Dock="Top" Text="{x:Static lang:Resources.Strategy_List}" Classes="sectionTitle"
                   Margin="0,0,0,8" />

        <!-- 底部操作按钮 -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
          <StackPanel Spacing="4">
            <Button Command="{Binding MoveUpCommand}"
                    CommandParameter="{Binding SelectedStrategy}"
                    AutomationProperties.Name="{x:Static lang:Resources.Strategy_MoveUp}"
                    HorizontalContentAlignment="Left" Padding="8,5">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUp}" FontSize="20" />
                <TextBlock Text="{x:Static lang:Resources.Strategy_MoveUp}" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Command="{Binding MoveDownCommand}"
                    CommandParameter="{Binding SelectedStrategy}"
                    AutomationProperties.Name="{x:Static lang:Resources.Strategy_MoveDown}"
                    HorizontalContentAlignment="Left" Padding="8,5">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowDown}" FontSize="20" />
                <TextBlock Text="{x:Static lang:Resources.Strategy_MoveDown}" FontSize="13" />
              </StackPanel>
            </Button>
            <Separator Margin="0,2" />
            <Button Command="{Binding SaveAllCommand}"
                    IsEnabled="{Binding HasChanges}"
                    AutomationProperties.Name="{x:Static lang:Resources.Strategy_SaveChangesHint}"
                    HorizontalContentAlignment="Left" Padding="8,5">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="20" />
                <TextBlock Text="{x:Static lang:Resources.Strategy_SaveChanges}" FontSize="13" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!-- 策略列表 -->
        <ListBox ItemsSource="{Binding Strategies}"
                 SelectedItem="{Binding SelectedStrategy, Mode=TwoWay}"
                 BorderThickness="0"
                 Background="{DynamicResource SidebarBackgroundBrush}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:StrategyItemViewModel">
              <StackPanel>
                <Border Padding="8,6" CornerRadius="4">
                  <Grid>
                    <DockPanel>
                      <ToggleSwitch DockPanel.Dock="Right"
                                    IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                    VerticalAlignment="Center" />
                      <!-- 左侧竖线（宿主策略或依赖子项，Markdown 引用风格） -->
                      <Border DockPanel.Dock="Left"
                              IsVisible="{Binding ShowLeftBar}"
                              Width="4"
                              Background="{DynamicResource SystemAccentColor}"
                              CornerRadius="2"
                              Margin="0,2,4,2"
                              VerticalAlignment="Stretch" />
                      <StackPanel Spacing="2" Margin="0,0,0,0">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" FontSize="13" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock FontSize="11"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                     Text="{Binding PriorityDisplay}" />
                          <Border CornerRadius="2" Padding="4,1"
                                  Background="{DynamicResource SystemControlAccentBrush}"
                                  IsVisible="{Binding IsBuiltIn, Converter={x:Static conv:BoolConverters.Negate}}">
                            <TextBlock Text="{x:Static lang:Resources.Strategy_Plugin}" FontSize="9" Foreground="White" />
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </DockPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- ═══════════ 右侧详情 ═══════════ -->
    <Grid Grid.Column="1">
      <!-- 空状态：未选中策略 -->
      <Border IsVisible="{Binding HasSelection, Converter={x:Static conv:BoolConverters.Negate}}"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Padding="40" CornerRadius="8"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Options}" FontSize="48"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          HorizontalAlignment="Center" />
          <TextBlock Text="{x:Static lang:Resources.Strategy_SelectHint2}" Classes="sectionTitle" HorizontalAlignment="Center" />
          <TextBlock Text="{x:Static lang:Resources.Strategy_SelectHint}" FontSize="12"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- 详情状态 -->
      <ScrollViewer IsVisible="{Binding HasDetail}" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
          <!-- 策略名称 + 来源标签 -->
          <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <StackPanel Spacing="8">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding SelectedDetail.DisplayName}"
                           Classes="pageTitle" VerticalAlignment="Center" />
                <Border DockPanel.Dock="Right" CornerRadius="4" Padding="8,3"
                        Background="{DynamicResource SystemControlAccentBrush}"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding DetailSourceDisplay}"
                             FontSize="11" Foreground="White" />
                </Border>
              </DockPanel>
              <TextBlock Text="{Binding SelectedDetail.Description}"
                         Classes="body" TextWrapping="Wrap"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Classes="bodySmall" Text="{Binding DetailAuthorDisplay}" Margin="0,4,0,0" />
                <TextBlock Classes="bodySmall" Text="{Binding DetailCategoryDisplay}" Margin="0,4,0,0" />
                <TextBlock Classes="bodySmall" Text="{Binding DetailDefaultPriorityDisplay}" Margin="0,4,0,0" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- 基本配置 -->
          <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <StackPanel Spacing="14">
              <TextBlock Text="{x:Static lang:Resources.Strategy_BasicConfig}" Classes="sectionTitle" />
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Strategy_PriorityLabel}" FontSize="14"
                           VerticalAlignment="Center" Width="140" />
                <NumericUpDown Value="{Binding EditPriority, Mode=TwoWay}"
                               Minimum="0" Maximum="999" Increment="1"
                               MinWidth="120" HorizontalAlignment="Right" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Strategy_EnableLabel}" FontSize="14"
                           VerticalAlignment="Center" Width="140" />
                <ToggleSwitch IsChecked="{Binding EditIsEnabled, Mode=TwoWay}"
                              HorizontalAlignment="Right" />
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- 策略参数（manifest parameters[] 驱动） -->
          <Border IsVisible="{Binding HasParameters}"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  CornerRadius="8" Padding="20">
            <ContentControl Content="{Binding ParameterEditor}" />
          </Border>

          <!-- 配置块（manifest codeBlocks[] 驱动） -->
          <ItemsControl ItemsSource="{Binding ConfigBlockEditors}" />

          <!-- 保存/重置按钮 -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button Command="{Binding ResetConfigCommand}"
                    HorizontalContentAlignment="Center" Padding="12,6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="16" />
                <TextBlock Text="{x:Static lang:Resources.Strategy_RestoreDefaults}" FontSize="14" />
              </StackPanel>
            </Button>
                <Button Command="{Binding SaveCurrentConfigCommand}"
                    HorizontalContentAlignment="Center" Padding="12,6"
                    IsDefault="True">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
                <TextBlock Text="{x:Static lang:Resources.Strategy_SaveConfig}" FontSize="14" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- 加载遮罩 -->
      <Border IsVisible="{Binding IsLoading}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
          <ProgressBar IsIndeterminate="True" Width="200" />
          <TextBlock Text="{x:Static lang:Resources.Common_Processing}" FontSize="14" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
