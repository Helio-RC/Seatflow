<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:local="clr-namespace:A_Pair.Presentation.Avalonia.Controls"
             x:Class="A_Pair.Presentation.Avalonia.Views.VenueConfigurationView"
             x:DataType="vm:VenueConfigurationViewModel">

  <Grid Margin="8">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320"/>
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0" Spacing="8">
      <TextBlock Text="会场类型" FontWeight="Bold"/>
      <ComboBox Items="{Binding LayoutTypes}" SelectedItem="{Binding SelectedLayoutType}" />
      <TextBlock Text="行数" />
      <TextBox Text="{Binding Rows}" />
      <TextBlock Text="列数" />
      <TextBox Text="{Binding Columns}" />
      <TextBlock Text="座位间距(px)" />
      <TextBox Text="{Binding SeatSpacing}" />
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="保存会场" Command="{Binding SaveVenueCommand}" />
        <Button Content="测试布局" Command="{Binding TestLayoutCommand}" />
      </StackPanel>
    </StackPanel>

    <Border Grid.Column="1" BorderThickness="1" BorderBrush="#CCC" Padding="8">
      <ScrollViewer>
        <local:SeatCanvas x:Name="PreviewCanvas" />
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
