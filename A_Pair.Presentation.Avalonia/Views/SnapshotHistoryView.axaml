<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:local="clr-namespace:A_Pair.Presentation.Avalonia.Controls"
             x:Class="A_Pair.Presentation.Avalonia.Views.SnapshotHistoryView"
             x:DataType="vm:SnapshotHistoryViewModel">

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="刷新" Command="{Binding RefreshCommand}" />
      <Button Content="对比" Command="{Binding CompareCommand}" />
      <Button Content="回滚" Command="{Binding ApplySnapshotCommand}" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <DataGrid Grid.Column="0" Items="{Binding Snapshots}" SelectedItem="{Binding SelectedSnapshot}" AutoGenerateColumns="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" />
          <DataGridTextColumn Header="描述" Binding="{Binding Description}" />
          <DataGridTextColumn Header="分配数" Binding="{Binding AssignedCount}" />
        </DataGrid.Columns>
      </DataGrid>

      <StackPanel Grid.Column="1" Margin="8">
        <TextBlock Text="选中快照预览" FontWeight="Bold" />
        <Border BorderBrush="#DDD" BorderThickness="1" Height="240">
          <local:SeatCanvas x:Name="SnapshotPreviewCanvas" />
        </Border>
        <TextBlock Text="{Binding SelectedSnapshotSummary}" TextWrapping="Wrap" Margin="0,8,0,0"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>