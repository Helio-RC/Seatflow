<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lang="using:A_Pair.Presentation.Avalonia.Lang"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:core="using:A_Pair.Core.Models"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.SnapshotHistoryView"
             x:DataType="vm:SnapshotHistoryViewModel">

  <DockPanel Margin="16">
    <!-- 顶部标题栏 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,16">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Snapshot_Title}" Classes="pageTitle"
                   VerticalAlignment="Center" />
        <!-- 想实现文字和按钮之间有间隔，但是没招了，给文字后面加了两个空格'😥' -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <!-- 会场下拉 -->
          <ComboBox ItemsSource="{Binding Venues}"
                    SelectedItem="{Binding SelectedVenue, Mode=TwoWay}"
                    Width="200" FontSize="13"
                    PlaceholderText="{x:Static lang:Resources.Snapshot_SelectVenue}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VenueItem">
                <TextBlock Text="{Binding Name}" FontSize="13"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Command="{Binding LoadVenuesCommand}"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowSync}" FontSize="14"/>
              <TextBlock Text="{x:Static lang:Resources.Common_Refresh}" FontSize="13"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding CreateSnapshotCommand}"
                  IsEnabled="{Binding CanCreateSnapshot}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Snapshot_Create}"
                  IsVisible="{Binding IsNotBatchMode}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="14"/>
              <TextBlock Text="{x:Static lang:Resources.Snapshot_Create}" FontSize="13"/>
            </StackPanel>
          </Button>
          <!-- 批量删除按钮（非批量模式） -->
          <Button Command="{Binding EnterBatchDeleteModeCommand}"
                  IsEnabled="{Binding CanEnterBatchDelete}"
                  IsVisible="{Binding IsNotBatchMode}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Snapshot_BatchDelete}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Delete}" FontSize="14"/>
              <TextBlock Text="{x:Static lang:Resources.Snapshot_BatchDelete}" FontSize="13"/>
            </StackPanel>
          </Button>
          <!-- 批量删除确认按钮（批量模式） -->
          <Button Command="{Binding ConfirmBatchDeleteCommand}"
                  IsVisible="{Binding IsBatchDeleteMode}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Snapshot_ConfirmDelete}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Delete}" FontSize="14"
                              Foreground="{DynamicResource ErrorBrush}"/>
              <TextBlock Text="{x:Static lang:Resources.Snapshot_ConfirmDelete}" FontSize="13"
                         Foreground="{DynamicResource ErrorBrush}"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding ExitBatchDeleteModeCommand}"
                  IsVisible="{Binding IsBatchDeleteMode}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Snapshot_BatchDelete}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{x:Static lang:Resources.Common_Cancel}" FontSize="13"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding SnapshotQuotaDisplay}"
                   Classes="caption" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBlock Text="{Binding StatusMessage}"
                   Classes="caption"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </DockPanel>
    </Border>

    <Grid ColumnDefinitions="280,4,*">
      <!-- 左侧：快照列表 -->
      <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="6" 
              Background="{DynamicResource SidebarBackgroundBrush}">
        <Grid RowDefinitions="Auto,*" Margin="8">
          <TextBlock Grid.Row="0" Text="{x:Static lang:Resources.Snapshot_List}"
                     FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

          <!-- 加载遮罩 -->
          <Border Grid.Row="1" IsVisible="{Binding IsLoading}"
                  Classes="loadingOverlay" ZIndex="10">
            <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
              <ProgressBar IsIndeterminate="True" Width="160" Height="4" />
              <TextBlock Text="{x:Static lang:Resources.Common_Loading}" Classes="caption"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- 正常模式 -->
          <Grid Grid.Row="1" IsVisible="{Binding IsNotBatchMode}">
            <!-- 空列表 -->
            <Border IsVisible="{Binding !HasSnapshots}">
              <StackPanel Spacing="8"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Margin="20">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.History}" FontSize="32"
                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                HorizontalAlignment="Center" />
                <TextBlock Text="{x:Static lang:Resources.Snapshot_NoSelectedVenue}"
                           Classes="caption" HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <!-- 正常模式列表 -->
            <ListBox ItemsSource="{Binding Snapshots}"
                     SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}"
                     IsVisible="{Binding HasSnapshots}"
                     BorderThickness="0"
                     Background="{DynamicResource SidebarBackgroundBrush}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="core:SeatingSnapshot">
                  <StackPanel Margin="4,4">
                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Description}"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap" MaxHeight="32"/>
                    <TextBlock Text="{Binding SeatAssignments.Count}"
                               Classes="micro"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>

          <!-- 批量模式 -->
          <StackPanel Grid.Row="1" IsVisible="{Binding IsBatchDeleteMode}">
            <CheckBox IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                      Margin="4,4,4,8" FontSize="13">
              <TextBlock Text="{Binding SelectAllDisplay}"
                         FontSize="13" />
            </CheckBox>
            <ListBox ItemsSource="{Binding CheckableItems}"
                     BorderThickness="0"
                     Background="{DynamicResource SidebarBackgroundBrush}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectableItem">
                  <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="4,4">
                    <StackPanel>
                      <TextBlock Text="{Binding Snapshot.CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                 FontSize="13" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Snapshot.Description}"
                                 FontSize="11"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                 TextWrapping="Wrap" MaxHeight="32"/>
                      <TextBlock Text="{Binding Snapshot.SeatAssignments.Count}"
                                 Classes="micro"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                  </CheckBox>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

      <!-- 右侧：详情 -->
      <Grid Grid.Column="2">
        <!-- 未选中 -->
        <Border IsVisible="{Binding !HasSelectedSnapshot}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Padding="40" CornerRadius="8">
          <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.History}" FontSize="48"
                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            HorizontalAlignment="Center" />
            <TextBlock Text="{x:Static lang:Resources.Snapshot_SelectHint}"
                       FontSize="14" HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </StackPanel>
        </Border>

        <!-- 详情（仅 SelectedSnapshot 非 null 时显示） -->
        <Border IsVisible="{Binding HasSelectedSnapshot}" Padding="16" CornerRadius="6"
                Background="{DynamicResource SidebarBackgroundBrush}">
          <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
              <Button Command="{Binding DeleteSnapshotCommand}"
                      HorizontalContentAlignment="Center"
                      AutomationProperties.Name="{x:Static lang:Resources.Snapshot_DeleteHint}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Delete}" FontSize="14"/>
                  <TextBlock Text="{x:Static lang:Resources.Common_Delete}" FontSize="13"/>
                </StackPanel>
              </Button>
              <Button Command="{Binding RollbackCommand}" Classes="accent"
                      HorizontalContentAlignment="Center"
                      IsEnabled="{Binding !HasRollbackDisabled}"
                      AutomationProperties.Name="{x:Static lang:Resources.Snapshot_RollbackHint}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="14"/>
                  <TextBlock Text="{x:Static lang:Resources.Snapshot_Rollback}" FontSize="13"/>
                </StackPanel>
              </Button>
            </StackPanel>

            <ScrollViewer>
              <StackPanel Spacing="14">
                <!-- 用 ContentControl + DataTemplate 防止 SelectedSnapshot 为 null 时绑定报错 -->
                <ContentControl Content="{Binding SelectedSnapshot}">
                  <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="core:SeatingSnapshot">
                      <StackPanel Spacing="10">
                        <TextBlock Text="{x:Static lang:Resources.Snapshot_Detail}" FontSize="16" FontWeight="SemiBold"/>
                        <StackPanel Spacing="4">
                          <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Static lang:Resources.Snapshot_Id}"/>
                          <TextBlock Text="{Binding Id}"
                                     FontSize="11" TextWrapping="Wrap"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                          <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Static lang:Resources.Snapshot_CreatedAt}"/>
                          <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                     Classes="caption"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                          <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Static lang:Resources.Snapshot_Description}"/>
                          <TextBlock Text="{Binding Description}"
                                     FontSize="12" TextWrapping="Wrap"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                          <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Static lang:Resources.Snapshot_SeatCount}"/>
                          <TextBlock Text="{Binding SeatAssignments.Count}"
                                     FontSize="12"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                          <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Static lang:Resources.Snapshot_LinkedVenue}"/>
                          <TextBlock Text="{Binding LayoutId}"
                                     FontSize="11" TextWrapping="Wrap"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                      </StackPanel>
                    </DataTemplate>
                  </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- 警告横幅 -->
                <Border IsVisible="{Binding IsVenueDeleted}" Padding="10" CornerRadius="4"
                        Classes="bgError">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static lang:Resources.Snapshot_VenueDeletedPreview}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource ErrorBrush}"/>
                    <TextBlock Text="{x:Static lang:Resources.Snapshot_VenueDeletedMsg}" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
                <Border IsVisible="{Binding IsVenueChanged}" Padding="10" CornerRadius="4"
                        Classes="bgWarning">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding VenueWarningText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="{x:Static lang:Resources.Snapshot_VenueChanged}" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
                <Border IsVisible="{Binding IsDataChanged}" Padding="10" CornerRadius="4"
                        Classes="bgWarning">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static lang:Resources.Snapshot_DataChanged}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="{x:Static lang:Resources.Snapshot_DataChangedMsg}" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <!-- 会场预览（绑定 ViewModel 属性，置于 ContentControl 外部避免 DataContext 错误） -->
                <Border IsVisible="{Binding HasPreview}" Padding="8" CornerRadius="4"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{x:Static lang:Resources.Snapshot_Preview}" FontSize="13" FontWeight="SemiBold"/>
                    <ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding PreviewSeats}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <Canvas Width="{Binding PreviewCanvasWidth}"
                                    Height="{Binding PreviewCanvasHeight}"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                          <Style Selector="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{ReflectionBinding X}"/>
                            <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}"/>
                          </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SeatDisplayItem">
                            <Border Width="{Binding Width}" Height="{Binding Height}"
                                    CornerRadius="{Binding CornerRadius}" BorderThickness="1"
                                    Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding BorderBrush}"
                                    ToolTip.Tip="{Binding TooltipText}">
                              <TextBlock Text="{Binding DisplayText}"
                                         FontSize="8" Margin="1"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis"/>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
