<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.settingRow">
      <Setter Property="Padding" Value="0,12,0,12" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeHighBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Border.settingRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
    </Style>

    <Style Selector="Button.linkButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="Button.linkButton:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorDark2}" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="16">
    <!-- 顶部标题栏 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,24">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="设置" Classes="pageTitle"
                   VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
          <Button Command="{Binding ResetDefaultsCommand}"
                  AutomationProperties.Name="恢复默认设置"
                  Classes="linkButton"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="14" />
              <TextBlock Text="恢复默认" FontSize="13" />
            </StackPanel>
          </Button>
          <Button Command="{Binding SaveSettingsCommand}"
                  AutomationProperties.Name="保存设置"
                  HorizontalContentAlignment="Center" Padding="10,4"
                  IsDefault="True">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="14" />
              <TextBlock Text="保存设置" FontSize="13" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
      <StackPanel>
        <Separator Margin="0,0,0,8" />
        <TextBlock Text="{Binding StatusMessage}" Classes="caption"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
    </Border>

    <!-- 中间内容 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0" MaxWidth="600">
        <!-- 外观 -->
        <TextBlock Text="外观" Classes="settingSectionHeader" Margin="0,0,0,6" />

        <Border Classes="settingRow">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="主题模式" Classes="body"
                       VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      AutomationProperties.Name="主题模式"
                      SelectedIndex="{Binding ThemeIndex, Mode=TwoWay}"
                      MinWidth="160" HorizontalAlignment="Right" FontSize="14" />
          </DockPanel>
        </Border>

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="座位图默认缩放" Classes="body"
                       VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ZoomOptions}"
                      AutomationProperties.Name="默认缩放"
                      SelectedIndex="{Binding ZoomIndex, Mode=TwoWay}"
                      MinWidth="160" HorizontalAlignment="Right" FontSize="14" />
          </DockPanel>
        </Border>

        <!-- 语言 -->
        <TextBlock Text="语言" Classes="settingSectionHeader" Margin="0,16,0,6" />

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="界面语言" Classes="body"
                       VerticalAlignment="Center" />
            <TextBox Text="{Binding Language, Mode=TwoWay}"
                     AutomationProperties.Name="界面语言"
                     PlaceholderText="留空跟随系统" MinWidth="200" HorizontalAlignment="Right"
                     ToolTip.Tip="语言代码，如 zh-CN、en-US" FontSize="14" />
          </DockPanel>
        </Border>

        <!-- 存储 -->
        <TextBlock Text="存储" Classes="settingSectionHeader" Margin="0,16,0,6" />

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="数据目录" Classes="body"
                       VerticalAlignment="Top" Margin="0,4,0,0" />
            <StackPanel HorizontalAlignment="Right" Spacing="6" MinWidth="280">
              <DockPanel>
                <Button Command="{Binding BrowseDataDirectoryCommand}"
                        AutomationProperties.Name="浏览数据目录"
                        DockPanel.Dock="Right" Padding="8,4">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Folder}" FontSize="16" />
                </Button>
                <TextBox Text="{Binding DataDirectory, Mode=TwoWay}"
                         PlaceholderText="留空使用默认位置" FontSize="14" />
              </DockPanel>
              <Button Command="{Binding OpenDataDirectoryCommand}"
                      AutomationProperties.Name="打开当前数据目录"
                      Classes="linkButton" HorizontalContentAlignment="Left" Padding="0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUpload}" FontSize="12" />
                  <TextBlock Text="打开当前数据目录" FontSize="12" />
                </StackPanel>
              </Button>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- 行为 -->
        <TextBlock Text="行为" Classes="settingSectionHeader" Margin="0,16,0,6" />

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="清除数据前确认" Classes="body"
                       VerticalAlignment="Center" />
            <ToggleSwitch IsChecked="{Binding ConfirmBeforeClear, Mode=TwoWay}"
                          AutomationProperties.Name="清除数据前确认"
                          HorizontalAlignment="Right" />
          </DockPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
