<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             xmlns:lang="using:A_Pair.Presentation.Avalonia.Lang"
             x:Class="A_Pair.Presentation.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.settingRow">
      <Setter Property="Padding" Value="0,12,0,12" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeHighBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Border.settingRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
    </Style>

    <Style Selector="Button.linkButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="Button.linkButton:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorDark2}" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="16">
    <!-- 顶部标题栏 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,24">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Settings_Title}"
                   Classes="pageTitle" VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
          <Button Command="{Binding ResetDefaultsCommand}"
                  AutomationProperties.Name="{x:Static lang:Resources.Settings_ResetDefaults}"
                  Classes="linkButton" HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="14" />
              <TextBlock Text="{x:Static lang:Resources.Settings_ResetDefaults}" FontSize="13" />
            </StackPanel>
          </Button>
          <Button Command="{Binding SaveSettingsCommand}"
                  AutomationProperties.Name="{x:Static lang:Resources.Settings_Save}"
                  HorizontalContentAlignment="Center" Padding="10,4" IsDefault="True">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="14" />
              <TextBlock Text="{x:Static lang:Resources.Settings_Save}" FontSize="13" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
      <StackPanel>
        <Separator Margin="0,0,0,8" />
        <TextBlock Text="{Binding StatusMessage}" Classes="caption"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
    </Border>

    <!-- 中间内容 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0" MaxWidth="600">
        <!-- 外观 -->
        <TextBlock Text="{x:Static lang:Resources.Settings_Appearance}"
                   Classes="settingSectionHeader" Margin="0,0,0,6" />

        <Border Classes="settingRow">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Settings_ThemeMode}"
                       Classes="body" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      AutomationProperties.Name="{x:Static lang:Resources.Settings_ThemeMode}"
                      SelectedIndex="{Binding ThemeIndex, Mode=TwoWay}"
                      MinWidth="160" HorizontalAlignment="Right" FontSize="14" />
          </DockPanel>
        </Border>

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Settings_DefaultZoom}"
                       Classes="body" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ZoomOptions}"
                      AutomationProperties.Name="{x:Static lang:Resources.Settings_DefaultZoom}"
                      SelectedIndex="{Binding ZoomIndex, Mode=TwoWay}"
                      MinWidth="160" HorizontalAlignment="Right" FontSize="14" />
          </DockPanel>
        </Border>

        <!-- 语言 -->
        <TextBlock Text="{x:Static lang:Resources.Settings_Language}"
                   Classes="settingSectionHeader" Margin="0,16,0,6" />

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Settings_LanguageLabel}"
                       Classes="body" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                      AutomationProperties.Name="{x:Static lang:Resources.Settings_LanguageLabel}"
                      MinWidth="180" HorizontalAlignment="Right" FontSize="14">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LanguageOption">
                  <TextBlock Text="{Binding DisplayName}" FontSize="14" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </DockPanel>
        </Border>

        <!-- 存储 -->
        <TextBlock Text="{x:Static lang:Resources.Settings_Storage}"
                   Classes="settingSectionHeader" Margin="0,16,0,6" />

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Settings_DataDir}"
                       Classes="body" VerticalAlignment="Top" Margin="0,4,0,0" />
            <StackPanel HorizontalAlignment="Right" Spacing="6" MinWidth="280">
              <DockPanel>
                <Button Command="{Binding BrowseDataDirectoryCommand}"
                        AutomationProperties.Name="{x:Static lang:Resources.Settings_BrowseDataDir}"
                        DockPanel.Dock="Right" Padding="8,4">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Folder}" FontSize="16" />
                </Button>
                <TextBox Text="{Binding DataDirectory, Mode=TwoWay}"
                         PlaceholderText="{x:Static lang:Resources.Settings_DataDirPlaceholder}"
                         FontSize="14" />
              </DockPanel>
              <Button Command="{Binding OpenDataDirectoryCommand}"
                      AutomationProperties.Name="{x:Static lang:Resources.Settings_OpenDataDir}"
                      Classes="linkButton" HorizontalContentAlignment="Left" Padding="0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUpload}" FontSize="12" />
                  <TextBlock Text="{x:Static lang:Resources.Settings_OpenDataDir}" FontSize="12" />
                </StackPanel>
              </Button>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- 行为 -->
        <TextBlock Text="{x:Static lang:Resources.Settings_Behavior}"
                   Classes="settingSectionHeader" Margin="0,16,0,6" />

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Settings_ConfirmClear}"
                       Classes="body" VerticalAlignment="Center" />
            <ToggleSwitch IsChecked="{Binding ConfirmBeforeClear, Mode=TwoWay}"
                          AutomationProperties.Name="{x:Static lang:Resources.Settings_ConfirmClear}"
                          HorizontalAlignment="Right" />
          </DockPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
