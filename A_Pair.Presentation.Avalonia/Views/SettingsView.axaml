<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             xmlns:fauic="using:FluentAvalonia.UI.Controls"
             x:Class="A_Pair.Presentation.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <DockPanel Margin="16">
    <!-- 顶部 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,16">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="设置" FontSize="20" FontWeight="Bold"
                   VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Command="{Binding ResetDefaultsCommand}"
                  HorizontalContentAlignment="Center" Padding="12,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="16" />
              <TextBlock Text="恢复默认" FontSize="14" />
            </StackPanel>
          </Button>
          <Button Command="{Binding SaveSettingsCommand}"
                  HorizontalContentAlignment="Center" Padding="12,6"
                  IsDefault="True">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
              <TextBlock Text="保存设置" FontSize="14" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
      <StackPanel>
        <Separator Margin="0,0,0,8" />
        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
    </Border>

    <!-- 中间内容 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="4" MaxWidth="560">

        <!-- 外观 -->
        <fauic:SettingsExpander Header="外观" IsExpanded="True">
          <fauic:SettingsExpanderItem Description="选择亮色、暗色或跟随系统主题">
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedIndex="{Binding ThemeIndex, Mode=TwoWay}"
                      MinWidth="160" FontSize="14" />
          </fauic:SettingsExpanderItem>
          <fauic:SettingsExpanderItem Description="Mica 仅 Windows 11，Acrylic 需要 Windows 10 1803+">
            <ComboBox ItemsSource="{Binding BackgroundMaterialOptions}"
                      SelectedIndex="{Binding BackgroundMaterialIndex, Mode=TwoWay}"
                      MinWidth="160" FontSize="14" />
          </fauic:SettingsExpanderItem>
        </fauic:SettingsExpander>

        <!-- 语言 -->
        <fauic:SettingsExpander Header="语言" IsExpanded="True">
          <fauic:SettingsExpanderItem Description="语言代码，如 zh-CN、en-US。留空跟随系统">
            <TextBox Text="{Binding Language, Mode=TwoWay}"
                     PlaceholderText="留空跟随系统" Width="200" FontSize="14" />
          </fauic:SettingsExpanderItem>
        </fauic:SettingsExpander>

        <!-- 数据目录 -->
        <fauic:SettingsExpander Header="存储" IsExpanded="True">
          <fauic:SettingsExpanderItem Description="用户数据、会场、快照等文件的存储位置。留空使用默认位置">
            <StackPanel Spacing="8" Orientation="Horizontal">
              <TextBox Text="{Binding DataDirectory, Mode=TwoWay}"
                       PlaceholderText="留空使用默认位置" FontSize="14"
                       MinWidth="240" />
              <Button Command="{Binding BrowseDataDirectoryCommand}" Padding="10,6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Folder}" FontSize="16" />
              </Button>
            </StackPanel>
          </fauic:SettingsExpanderItem>
          <fauic:SettingsExpanderItem Description="在文件管理器中打开当前数据目录">
            <Button Command="{Binding OpenDataDirectoryCommand}"
                    HorizontalContentAlignment="Left" Padding="8,6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUpload}" FontSize="14" />
                <TextBlock Text="打开当前数据目录" FontSize="13" />
              </StackPanel>
            </Button>
          </fauic:SettingsExpanderItem>
        </fauic:SettingsExpander>

        <!-- 行为 -->
        <fauic:SettingsExpander Header="行为" IsExpanded="True">
          <fauic:SettingsExpanderItem Description="自动保存工作进度的间隔时间，选择「禁用」关闭自动保存">
            <ComboBox ItemsSource="{Binding AutoSaveOptions}"
                      SelectedIndex="{Binding AutoSaveIndex, Mode=TwoWay}"
                      MinWidth="160" FontSize="14" />
          </fauic:SettingsExpanderItem>
          <fauic:SettingsExpanderItem Description="避免误操作，清除数据前需要用户确认">
            <ToggleSwitch IsChecked="{Binding ConfirmBeforeClear, Mode=TwoWay}" />
          </fauic:SettingsExpanderItem>
          <fauic:SettingsExpanderItem Description="新生成的座位安排默认显示比例">
            <ComboBox ItemsSource="{Binding ZoomOptions}"
                      SelectedIndex="{Binding ZoomIndex, Mode=TwoWay}"
                      MinWidth="160" FontSize="14" />
          </fauic:SettingsExpanderItem>
        </fauic:SettingsExpander>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
