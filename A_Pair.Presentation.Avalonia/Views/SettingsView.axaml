<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <DockPanel Margin="16">
    <!-- 顶部 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,16">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="设置" FontSize="20" FontWeight="Bold"
                   VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Command="{Binding ResetDefaultsCommand}"
                  HorizontalContentAlignment="Center" Padding="12,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="16" />
              <TextBlock Text="恢复默认" FontSize="14" />
            </StackPanel>
          </Button>
          <Button Command="{Binding SaveSettingsCommand}"
                  HorizontalContentAlignment="Center" Padding="12,6"
                  IsDefault="True">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
              <TextBlock Text="保存设置" FontSize="14" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
      <StackPanel>
        <Separator Margin="0,0,0,8" />
        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
    </Border>

    <!-- 中间内容 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16" MaxWidth="600">
        <!-- 外观 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="外观" FontSize="16" FontWeight="SemiBold" />
            <Separator />
            <StackPanel Spacing="8">
              <TextBlock Text="主题模式" FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Command="{Binding SelectThemeCommand}" CommandParameter="0"
                        Padding="16,8" FontSize="14" Content="跟随系统" />
                <Button Command="{Binding SelectThemeCommand}" CommandParameter="1"
                        Padding="16,8" FontSize="14" Content="浅色" />
                <Button Command="{Binding SelectThemeCommand}" CommandParameter="2"
                        Padding="16,8" FontSize="14" Content="深色" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- 语言 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="语言" FontSize="16" FontWeight="SemiBold" />
            <Separator />
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="界面语言" FontSize="14"
                         VerticalAlignment="Center" Margin="0,0,12,0" />
              <TextBox DockPanel.Dock="Left" Text="{Binding Language, Mode=TwoWay}"
                       PlaceholderText="留空跟随系统" Width="160" FontSize="14"
                       ToolTip.Tip="语言代码，如 zh-CN、en-US。留空则跟随系统。"/>
            </DockPanel>
          </StackPanel>
        </Border>

        <!-- 数据目录 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="存储" FontSize="16" FontWeight="SemiBold" />
            <Separator />
            <StackPanel Spacing="8">
              <TextBlock Text="数据目录" FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding DataDirectory, Mode=TwoWay}"
                         PlaceholderText="留空使用默认位置" FontSize="14"
                         MinWidth="280" />
                <Button Command="{Binding BrowseDataDirectoryCommand}"
                        Padding="10,6">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Folder}" FontSize="16" />
                    <TextBlock Text="浏览" FontSize="14" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- 行为 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20" Margin="0,0,0,16">
          <StackPanel Spacing="16">
            <TextBlock Text="行为" FontSize="16" FontWeight="SemiBold" />
            <Separator />

            <!-- 自动保存间隔 -->
            <StackPanel Spacing="8">
              <TextBlock Text="自动保存间隔" FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="禁用" Padding="12,6" FontSize="13"
                        Command="{Binding SetAutoSaveCommand}" CommandParameter="0" />
                <Button Content="1 分钟" Padding="12,6" FontSize="13"
                        Command="{Binding SetAutoSaveCommand}" CommandParameter="60" />
                <Button Content="5 分钟" Padding="12,6" FontSize="13"
                        Command="{Binding SetAutoSaveCommand}" CommandParameter="300" />
                <Button Content="10 分钟" Padding="12,6" FontSize="13"
                        Command="{Binding SetAutoSaveCommand}" CommandParameter="600" />
              </StackPanel>
              <TextBlock FontSize="11"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                <TextBlock.Text>
                  <Binding Path="AutoSaveIntervalSeconds" StringFormat="当前间隔：{0} 秒" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>

            <Separator />

            <!-- 清除确认 -->
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="清除数据前弹出确认对话框" FontSize="14"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <ToggleSwitch IsChecked="{Binding ConfirmBeforeClear, Mode=TwoWay}"
                            HorizontalAlignment="Right" />
            </DockPanel>

            <Separator />

            <!-- 默认缩放 -->
            <StackPanel Spacing="8">
              <TextBlock Text="座位图默认缩放" FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="75%" Padding="12,6" FontSize="13"
                        Command="{Binding SetZoomCommand}" CommandParameter="0.75" />
                <Button Content="100%" Padding="12,6" FontSize="13"
                        Command="{Binding SetZoomCommand}" CommandParameter="1.0" />
                <Button Content="125%" Padding="12,6" FontSize="13"
                        Command="{Binding SetZoomCommand}" CommandParameter="1.25" />
                <Button Content="150%" Padding="12,6" FontSize="13"
                        Command="{Binding SetZoomCommand}" CommandParameter="1.5" />
              </StackPanel>
              <TextBlock FontSize="11"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                <TextBlock.Text>
                  <Binding Path="DefaultZoomLevel" StringFormat="当前：{0:P0}" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
