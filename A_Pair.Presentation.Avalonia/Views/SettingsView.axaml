<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <DockPanel Margin="16">
    <!-- 顶部 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,16">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="设置" FontSize="20" FontWeight="Bold"
                   VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Command="{Binding ResetDefaultsCommand}"
                  HorizontalContentAlignment="Center" Padding="12,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="16" />
              <TextBlock Text="恢复默认" FontSize="14" />
            </StackPanel>
          </Button>
          <Button Command="{Binding SaveSettingsCommand}"
                  HorizontalContentAlignment="Center" Padding="12,6"
                  IsDefault="True">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
              <TextBlock Text="保存设置" FontSize="14" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
      <StackPanel>
        <Separator Margin="0,0,0,8" />
        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
    </Border>

    <!-- 中间内容 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16" MaxWidth="560">
        <!-- 外观 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="外观" FontSize="16" FontWeight="SemiBold" />
            <Separator />

            <!-- 主题模式 -->
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="主题模式" FontSize="14"
                         VerticalAlignment="Center" Width="140" />
              <ComboBox ItemsSource="{Binding ThemeOptions}"
                        SelectedIndex="{Binding ThemeIndex, Mode=TwoWay}"
                        MinWidth="160" FontSize="14" />
            </DockPanel>

            <Separator />
          </StackPanel>
        </Border>

        <!-- 语言 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="语言" FontSize="16" FontWeight="SemiBold" />
            <Separator />
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="界面语言" FontSize="14"
                         VerticalAlignment="Center" Width="140" />
              <TextBox Text="{Binding Language, Mode=TwoWay}"
                       PlaceholderText="留空跟随系统" Width="200" FontSize="14"
                       ToolTip.Tip="语言代码，如 zh-CN、en-US。留空则跟随系统。"/>
            </DockPanel>
          </StackPanel>
        </Border>

        <!-- 数据目录 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="存储" FontSize="16" FontWeight="SemiBold" />
            <Separator />
            <StackPanel Spacing="8">
              <TextBlock Text="数据目录" FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding DataDirectory, Mode=TwoWay}"
                         PlaceholderText="留空使用默认位置" FontSize="14"
                         MinWidth="240" />
                <Button Command="{Binding BrowseDataDirectoryCommand}" Padding="10,6">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Folder}" FontSize="16" />
                </Button>
              </StackPanel>
              <Button Command="{Binding OpenDataDirectoryCommand}"
                      HorizontalContentAlignment="Left" Padding="8,6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUpload}" FontSize="14" />
                  <TextBlock Text="打开当前数据目录" FontSize="13" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- 行为 -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="20" Margin="0,0,0,16">
          <StackPanel Spacing="14">
            <TextBlock Text="行为" FontSize="16" FontWeight="SemiBold" />
            <Separator />

            <!-- 自动保存间隔 -->
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="自动保存间隔" FontSize="14"
                         VerticalAlignment="Center" Width="140" />
              <ComboBox ItemsSource="{Binding AutoSaveOptions}"
                        SelectedIndex="{Binding AutoSaveIndex, Mode=TwoWay}"
                        MinWidth="160" FontSize="14" />
            </DockPanel>

            <Separator />

            <!-- 清除确认 -->
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="清除数据前确认" FontSize="14"
                         VerticalAlignment="Center" Width="140" />
              <ToggleSwitch IsChecked="{Binding ConfirmBeforeClear, Mode=TwoWay}"
                            HorizontalAlignment="Right" />
            </DockPanel>

            <Separator />

            <!-- 默认缩放 -->
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="座位图默认缩放" FontSize="14"
                         VerticalAlignment="Center" Width="140" />
              <ComboBox ItemsSource="{Binding ZoomOptions}"
                        SelectedIndex="{Binding ZoomIndex, Mode=TwoWay}"
                        MinWidth="160" FontSize="14" />
            </DockPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
