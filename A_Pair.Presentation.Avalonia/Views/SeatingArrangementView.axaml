<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:local="clr-namespace:A_Pair.Presentation.Avalonia.Controls"
             x:Class="A_Pair.Presentation.Avalonia.Views.SeatingArrangementView"
             x:DataType="vm:SeatingArrangementViewModel">

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="ЙъіЙЧщО»±н" Command="{Binding GenerateSeatingCommand}" />
      <Button Content="їЄКјВЦ»»" Command="{Binding StartRotationCommand}" />
      <Button Content="ЗеїХ·ЦЕд" Command="{Binding ClearAssignmentsCommand}" />
      <Button Content="µјіцКУНј..." Command="{Binding ExportViewCommand}" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <TextBlock Text="Лх·Е:" VerticalAlignment="Center" Margin="12,0,4,0"/>
        <Button Content="+" Command="{Binding ZoomInCommand}" Width="28"/>
        <Button Content="-" Command="{Binding ZoomOutCommand}" Width="28" Margin="4,0,0,0"/>
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="300" />
      </Grid.ColumnDefinitions>

      <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <local:SeatCanvas x:Name="SeatCanvas" />
      </ScrollViewer>

      <StackPanel Grid.Column="1" Margin="8" Spacing="8">
        <TextBlock Text="Оґ·ЦЕдС§Йъ" FontWeight="Bold"/>
        <ListBox Items="{Binding UnassignedStudents}" DisplayMemberPath="Name"
                 SelectedItem="{Binding SelectedUnassignedStudent}" />
        <TextBlock Text="ЧщО»РЕПў / ВЦ»»ЅЁТй" FontWeight="Bold" Margin="0,8,0,0"/>
        <TextBlock Text="{Binding SelectedSeatInfo}" TextWrapping="Wrap" />
        <Button Content="ІйїґёГЙъВЦ»»ПкЗй" Command="{Binding ShowStudentHistoryCommand}" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
