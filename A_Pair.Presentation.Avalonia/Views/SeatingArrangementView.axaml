<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lang="using:A_Pair.Presentation.Avalonia.Lang"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:core="using:A_Pair.Core.Models"
             xmlns:conv="using:A_Pair.Presentation.Avalonia.Converters"
             xmlns:behaviors="using:A_Pair.Presentation.Avalonia.Behaviors"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.SeatingArrangementView"
             x:DataType="vm:SeatingArrangementViewModel">

  <DockPanel Classes="pageMargin">
    <!-- ═══ 工具栏 ═══ -->
    <Border DockPanel.Dock="Top" Classes="sectionSpacing">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Seating_Title}" Classes="pageTitle"
                   VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <!-- 导出按钮 + Flyout -->
          <Button x:Name="ExportButton" IsEnabled="{Binding HasGenerated}" HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Data_Export}">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Excel (.xlsx)" Command="{Binding ExportExcelCommand}">
                  <MenuItem.Icon>
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Document}" FontSize="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="CSV (.csv)" Command="{Binding ExportCsvCommand}">
                  <MenuItem.Icon>
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Document}" FontSize="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="PDF (.pdf)" Command="{Binding ExportPdfCommand}">
                  <MenuItem.Icon>
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.DocumentPdf}" FontSize="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{x:Static lang:Resources.Seating_ExportPNG}" Command="{Binding ExportImageCommand}">
                  <MenuItem.Icon>
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Image}" FontSize="14" />
                  </MenuItem.Icon>
                </MenuItem>
              </MenuFlyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.SaveArrowRight}" FontSize="16" />
              <TextBlock Text="{x:Static lang:Resources.Seating_Export}" FontSize="14" />
            </StackPanel>
          </Button>
          <!-- 保存到快照 -->
          <Button x:Name="SaveSnapshotButton" Command="{Binding SaveToSnapshotCommand}"
                  IsEnabled="{Binding HasUnsavedChanges}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Seating_SaveSnapshot}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
              <TextBlock Text="{x:Static lang:Resources.Common_Save}" FontSize="14" />
            </StackPanel>
          </Button>
          <!-- 撤销 -->
          <Button x:Name="UndoButton" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Seating_UndoSwap}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="16" />
              <TextBlock Text="{x:Static lang:Resources.Seating_Undo}" FontSize="14" />
            </StackPanel>
          </Button>
          <!-- 重做 -->
          <Button Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.Name="{x:Static lang:Resources.Seating_RedoSwap}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowRedo}" FontSize="16" />
              <TextBlock Text="{x:Static lang:Resources.Seating_Redo}" FontSize="14" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══ 状态栏 ═══ -->
    <Border DockPanel.Dock="Bottom" Classes="statusBarBottom"
            IsVisible="{Binding HasGenerated}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Classes="caption"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
          <TextBlock Classes="caption">
            <Run Text="{x:Static lang:Resources.Seating_Seats}"/>
            <Run Text="{Binding AssignedSeats}"/>
            <Run Text="/"/>
            <Run Text="{Binding TotalSeats}"/>
          </TextBlock>
          <TextBlock Classes="caption">
            <Run Text="{x:Static lang:Resources.Seating_Unassigned}"/>
            <Run Text="{Binding UnassignedStudentCount}"/>
            <Run Text="{x:Static lang:Resources.Seating_People}"/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 交换提示栏 -->
    <Border DockPanel.Dock="Bottom" Classes="statusBarBottom"
            IsVisible="{Binding IsSwapMode}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding SwapHintText}" Classes="caption"
                   Foreground="{DynamicResource SystemAccentColor}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1" Command="{Binding CancelSwapCommand}"
                AutomationProperties.Name="{x:Static lang:Resources.Seating_CancelSwap}"
                Padding="8,2" FontSize="12">
          <TextBlock Text="{x:Static lang:Resources.Common_Cancel}"/>
        </Button>
      </Grid>
    </Border>

    <!-- ═══ 三栏内容区 ═══ -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- ─── 左侧面板 ─── -->
      <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="6"
              ClipToBounds="True"
              Background="{DynamicResource SidebarBackgroundBrush}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="8">
          <!-- 会场选择 -->
          <TextBlock Grid.Row="0" Text="{x:Static lang:Resources.Seating_Venue}" Classes="sectionTitle" Margin="3,0,0,8" />
          <ListBox x:Name="VenueListBox" Grid.Row="1" ItemsSource="{Binding VenueItems}"
                   SelectedItem="{Binding SelectedVenue, Mode=TwoWay}"
                   MaxHeight="180" BorderThickness="0"
                   Background="{DynamicResource SidebarBackgroundBrush}"
                   AutomationProperties.Name="{x:Static lang:Resources.Venue_List}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VenueItem">
                <TextBlock Text="{Binding Name}" Classes="bodySmall" Margin="4,6" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Separator Grid.Row="2" Margin="4,10" />

          <!-- 数据集选择 -->
          <TextBlock Grid.Row="3" Text="{x:Static lang:Resources.Seating_MemberData}" Classes="sectionTitle" Margin="3,0,0,8" />
          <ListBox x:Name="DatasetListBox" Grid.Row="4" ItemsSource="{Binding DatasetItems}"
                   SelectedItem="{Binding SelectedDataset, Mode=TwoWay}"
                   MaxHeight="180" BorderThickness="0"
                   Background="{DynamicResource SidebarBackgroundBrush}"
                   AutomationProperties.Name="{x:Static lang:Resources.Seating_MemberDatasetList}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="core:StudentDatasetInfo">
                <TextBlock Text="{Binding Name}" Classes="bodySmall" Margin="4,6" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- 填充 spacer -->
          <Panel Grid.Row="5" />

          <!-- 生成 + 创建空白会场按钮 -->
          <DockPanel Grid.Row="6" Margin="0,8">
            <Button DockPanel.Dock="Right"
                    Command="{Binding CreateEmptySeatingCommand}"
                    IsEnabled="{Binding CanCreateEmpty}"
                    Width="36" Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    AutomationProperties.Name="{x:Static lang:Resources.Seating_CreateEmpty}"
                    ToolTip.Tip="{x:Static lang:Resources.Seating_CreateEmpty}"
                    Classes="accent">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Add}" FontSize="18" />
            </Button>
            <Button x:Name="GenerateButton"
                    Command="{Binding GenerateSeatingCommand}"
                    IsEnabled="{Binding CanGenerate}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    AutomationProperties.Name="{x:Static lang:Resources.Seating_Title}"
                    Height="36" Margin="0,0,4,0">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Play}" FontSize="16" />
                <TextBlock Text="{x:Static lang:Resources.Seating_Generate}" FontSize="14" />
              </StackPanel>
            </Button>
          </DockPanel>
        </Grid>
      </Border>

      <!-- GridSplitter -->
      <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                    HorizontalAlignment="Stretch" />

      <!-- ─── 中央 Canvas + 右侧面板 ─── -->
      <Grid Grid.Column="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ═══ 座位图 Canvas ═══ -->
        <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="0">
          <Panel>

            <!-- 空状态 -->
            <Border IsVisible="{Binding HasGenerated, Converter={x:Static conv:BoolConverters.Negate}}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Padding="40">
              <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Grid}" FontSize="48"
                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                HorizontalAlignment="Center" />
                <TextBlock Text="{x:Static lang:Resources.Seating_NotGenerated}" Classes="sectionTitle"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Text="{x:Static lang:Resources.Seating_NotGeneratedHint}"
                           Classes="caption" HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- 座位渲染区 -->
            <ScrollViewer x:Name="PreviewScrollViewer" IsVisible="{Binding HasGenerated}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource PreviewBackgroundBrush}"
                          behaviors:CanvasZoomPan.Enabled="True"
                          behaviors:ZoomOnScroll.Enabled="True"
                          behaviors:ZoomOnScroll.OnZoom="{Binding ZoomAction}">
              <Panel Name="SeatDragPanel"
                     PointerMoved="SeatDragPanel_PointerMoved"
                     PointerReleased="SeatDragPanel_PointerReleased"
                     Background="Transparent">
                <ItemsControl ItemsSource="{Binding SeatItems}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas Width="{Binding $parent[UserControl].DataContext.CanvasWidth, Mode=OneWay}"
                              Height="{Binding $parent[UserControl].DataContext.CanvasHeight, Mode=OneWay}" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{ReflectionBinding X}" />
                      <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}" />
                    </Style>
                  </ItemsControl.Styles>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SeatDisplayItem">
                      <Border Width="{ReflectionBinding Width}"
                              Height="{ReflectionBinding Height}"
                              CornerRadius="{ReflectionBinding CornerRadius}"
                              BorderThickness="2"
                              Background="{ReflectionBinding BackgroundBrush}"
                              BorderBrush="{ReflectionBinding BorderBrush}"
                              Cursor="Hand"
                              ToolTip.Tip="{ReflectionBinding TooltipText}"
                              DragDrop.DragOver="Seat_DragOver"
                              DragDrop.Drop="Seat_Drop"
                              DragDrop.DragLeave="Seat_DragLeave"
                              PointerPressed="SeatBorder_PointerPressed">
                        <TextBlock Text="{ReflectionBinding DisplayText}"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   Margin="2,0" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding OverlayItems}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas Width="{Binding $parent[UserControl].DataContext.CanvasWidth, Mode=OneWay}"
                              Height="{Binding $parent[UserControl].DataContext.CanvasHeight, Mode=OneWay}" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.Styles>
                    <Style Selector="ItemsControl > ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{ReflectionBinding X}" />
                      <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}" />
                    </Style>
                  </ItemsControl.Styles>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SeatDisplayItem">
                      <Border Width="{ReflectionBinding Width}"
                              Height="{ReflectionBinding Height}"
                              CornerRadius="{ReflectionBinding CornerRadius}"
                              Background="{ReflectionBinding BackgroundBrush}"
                              BorderBrush="{ReflectionBinding BorderBrush}"
                              BorderThickness="1"
                              ToolTip.Tip="{ReflectionBinding TooltipText}">
                        <TextBlock Text="{ReflectionBinding DisplayText}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Panel>
            </ScrollViewer>
            <!-- 垃圾桶：拖入或点击移除学生 -->
            <Border Name="TrashZone"
                    IsVisible="{Binding HasGenerated}"
                    AutomationProperties.Name="{x:Static lang:Resources.Seating_TrashHint}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,12,36"
                    Width="44" Height="44" CornerRadius="22"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="2"
                    DragDrop.DragOver="Trash_DragOver"
                    DragDrop.Drop="Trash_Drop"
                    DragDrop.DragLeave="Trash_DragLeave"
                    PointerPressed="Trash_PointerPressed"
                    Cursor="Hand"
                    ToolTip.Tip="{x:Static lang:Resources.Seating_TrashHint}"
                    ZIndex="10">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Delete}" FontSize="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </Border>
            <TextBlock Text="{x:Static lang:Resources.Seating_CanvasHint}" Classes="small" Opacity="0.4"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,12,8"
                       IsVisible="{Binding HasGenerated}"/>
          </Panel>
        </Border>

        <!-- ═══ 右侧面板 ═══ -->
        <Border Grid.Column="1" Margin="8,0,0,0" CornerRadius="6"
                Padding="8" Width="240"
                Background="{DynamicResource SidebarBackgroundBrush}"
                IsVisible="{Binding HasGenerated}">
          <ScrollViewer>
            <StackPanel Spacing="8">
              <!-- ── 策略列表 (可折叠) ── -->
              <StackPanel>
                <Button Command="{Binding ToggleStrategiesCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalContentAlignment="Stretch"
                        Cursor="Hand">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Seating_CurrentStrategy}" Classes="sectionTitle" />
                    <fic:FluentIcon DockPanel.Dock="Right"
                        Icon="{x:Static ficEnum:Icon.ChevronUp}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsStrategiesExpanded}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <fic:FluentIcon DockPanel.Dock="Right"
                        Icon="{x:Static ficEnum:Icon.ChevronDown}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsStrategiesExpanded, Converter={x:Static conv:BoolConverters.Negate}}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </DockPanel>
                </Button>
                <ItemsControl ItemsSource="{Binding ActiveStrategies}"
                              IsVisible="{Binding IsStrategiesExpanded}"
                              MaxHeight="200">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:StrategyDisplayInfo">
                      <StackPanel>
                        <!-- 父策略项：有子项时左侧竖线 -->
                        <DockPanel Margin="4,3">
                          <Border DockPanel.Dock="Left"
                                  IsVisible="{Binding HasDependentChildren}"
                                  Width="4"
                                  Background="{DynamicResource SystemAccentColor}"
                                  CornerRadius="2"
                                  Margin="0,2,4,2"
                                  VerticalAlignment="Stretch" />
                          <Border CornerRadius="3" Padding="4,1"
                                  Background="{DynamicResource SystemAccentColor}"
                                  Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Priority}" Classes="micro"
                                       Foreground="White" />
                          </Border>
                          <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                            <TextBlock Text="{Binding Category}" Classes="small"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                          </StackPanel>
                        </DockPanel>
                        <!-- 依赖策略子项：平级，左侧竖线区分 -->
                        <ItemsControl ItemsSource="{Binding DependentChildren}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:StrategyDisplayInfo">
                              <DockPanel Margin="4,1">
                                <Border DockPanel.Dock="Left"
                                        Width="4"
                                        Background="{DynamicResource SystemAccentColor}"
                                        CornerRadius="2"
                                        Margin="0,2,4,2"
                                        VerticalAlignment="Stretch" />
                                <Border CornerRadius="3" Padding="4,1"
                                        Background="{DynamicResource SystemAccentColor}"
                                        Margin="0,0,8,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding Priority}" Classes="micro"
                                             Foreground="White" />
                                </Border>
                                <StackPanel>
                                  <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                                  <TextBlock Text="{Binding Category}" Classes="small"
                                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </StackPanel>
                              </DockPanel>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <Separator />

              <!-- ── 未分配学生 (可折叠) ── -->
              <StackPanel>
                <Button Command="{Binding ToggleUnassignedCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalContentAlignment="Stretch"
                        Cursor="Hand">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Classes="bodyStrong">
                      <Run Text="{x:Static lang:Resources.Seating_UnassignedMembers}" />
                      <!-- Run 不是 StyledElement，Typography 样式类（TextBlock.* 选择器）无法匹配，只能用内联 FontSize -->
                      <Run Text="{Binding UnassignedStudentCount, StringFormat=' ({0})'}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </TextBlock>
                    <fic:FluentIcon DockPanel.Dock="Right"
                        Icon="{x:Static ficEnum:Icon.ChevronUp}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsUnassignedExpanded}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <fic:FluentIcon DockPanel.Dock="Right"
                        Icon="{x:Static ficEnum:Icon.ChevronDown}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsUnassignedExpanded, Converter={x:Static conv:BoolConverters.Negate}}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </DockPanel>
                </Button>
                <ListBox ItemsSource="{Binding UnassignedStudents}"
                         SelectedItem="{Binding SelectedUnassignedStudent, Mode=TwoWay}"
                         IsVisible="{Binding IsUnassignedExpanded}"
                         BorderThickness="0"
                         Background="{DynamicResource SidebarBackgroundBrush}"
                         AutomationProperties.Name="{x:Static lang:Resources.Seating_UnassignedMembers}"
                         PointerMoved="UnassignedList_PointerMoved"
                         PointerReleased="UnassignedList_PointerReleased">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="core:Student">
                      <TextBlock Text="{Binding Name}" Classes="bodySmall" Margin="4,4"
                                 PointerPressed="UnassignedStudent_PointerPressed" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>

              <Separator IsVisible="{Binding HasHistory}" />

              <!-- ── 修改记录 (可折叠) ── -->
              <StackPanel IsVisible="{Binding HasHistory}">
                <DockPanel Margin="0,0,0,4">
                  <Button DockPanel.Dock="Left" Command="{Binding ToggleHistoryCommand}"
                          Background="Transparent" BorderThickness="0"
                          Padding="0" Cursor="Hand">
                    <TextBlock Text="{x:Static lang:Resources.Seating_History}" Classes="sectionTitle" />
                  </Button>
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ChevronUp}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsHistoryExpanded}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ChevronDown}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsHistoryExpanded, Converter={x:Static conv:BoolConverters.Negate}}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <Button Command="{Binding RestoreToSelectedCommand}"
                            IsEnabled="{Binding HasSelectedHistory}"
                            Padding="8,4" HorizontalContentAlignment="Center">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowUndo}" FontSize="14" />
                        <TextBlock Text="{x:Static lang:Resources.Seating_Restore}" Classes="bodySmall" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </DockPanel>
                <ListBox ItemsSource="{Binding HistoryEntries}"
                         SelectedItem="{Binding SelectedHistory, Mode=TwoWay}"
                         IsVisible="{Binding IsHistoryExpanded}"
                         BorderThickness="0" MaxHeight="220"
                         Background="{DynamicResource SidebarBackgroundBrush}">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="6,3" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ Border#PART_BackgroundBorder">
                      <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight2}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                      <Setter Property="BorderThickness" Value="1" />
                      <Setter Property="CornerRadius" Value="4" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:HistoryEntry">
                      <StackPanel Margin="0,2">
                        <TextBlock Text="{Binding Description}" Classes="bodySmall"
                                   FontWeight="{Binding IsCurrent, Converter={x:Static conv:BoolConverters.TrueToBold}}" />
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                   Classes="micro"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>

              <Separator IsVisible="{Binding HasMessages}" />

              <!-- ── 策略消息 (可折叠) ── -->
              <StackPanel IsVisible="{Binding HasMessages}">
                <Button Command="{Binding ToggleMessagesCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalContentAlignment="Stretch"
                        Cursor="Hand">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="{x:Static lang:Resources.Seating_StrategyMessages}"
                               Classes="sectionTitle" />
                    <fic:FluentIcon DockPanel.Dock="Right"
                        Icon="{x:Static ficEnum:Icon.ChevronUp}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsMessagesExpanded}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <fic:FluentIcon DockPanel.Dock="Right"
                        Icon="{x:Static ficEnum:Icon.ChevronDown}" FontSize="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsMessagesExpanded, Converter={x:Static conv:BoolConverters.Negate}}"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </DockPanel>
                </Button>
                <ScrollViewer IsVisible="{Binding IsMessagesExpanded}" MaxHeight="300">
                  <ItemsControl ItemsSource="{Binding MessageGroups}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:StrategyMessageGroup">
                        <StackPanel Margin="0,4">
                          <!-- 分组标题：错误 (n) / 警告 (n) -->
                          <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                     Margin="4,2,0,4"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                          <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:StrategyMessageItem">
                                <Border Margin="4,1" Padding="6,4" CornerRadius="4"
                                        Background="{DynamicResource SystemControlBackgroundSubtleBrush}">
                                  <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding StrategyName}" FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SystemAccentColor}" />
                                    <TextBlock Text="{Binding Message}" Classes="small"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               TextWrapping="Wrap" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>

      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
