<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="A_Pair.Presentation.Avalonia.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             x:Name="AboutHost">

  <Design.DataContext>
    <vm:AboutViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.settingRow">
      <Setter Property="Padding" Value="0,10,0,10" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeHighBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Border.settingRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
    </Style>

    <Style Selector="Button.linkButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="4,2" />
    </Style>
    <Style Selector="Button.linkButton:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorDark2}" />
    </Style>

    <Style Selector="Button.depLink">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="4" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="16">
    <!-- 顶部标题 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,24">
      <TextBlock Text="关于" Classes="pageTitle" VerticalAlignment="Center" />
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0" MaxWidth="520" HorizontalAlignment="Center">

        <!-- 应用信息头部 -->
        <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,8,0,0">
          <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Grid}" FontSize="48" Height="48"
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource SystemAccentColor}" />
          <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold"
                     HorizontalAlignment="Center" />
          <TextBlock HorizontalAlignment="Center" FontSize="13"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
            <Binding Path="Version" StringFormat="版本 {0}" />
          </TextBlock>
        </StackPanel>

        <!-- 描述 -->
        <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap"
                   HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   Margin="0,12,0,0" />

        <Separator Margin="0,12,0,8" />

        <!-- 运行环境 -->
        <TextBlock Text="运行环境" Classes="settingSectionHeader" Margin="0,8,0,6" />

        <Border Classes="settingRow">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="运行框架" Classes="body"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding RuntimeVersion}" Classes="body"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </DockPanel>
        </Border>

        <Border Classes="settingRow">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="Avalonia UI" Classes="body"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding AvaloniaVersion}" Classes="body"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </DockPanel>
        </Border>

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="许可证" Classes="body"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding License}" Classes="body"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </DockPanel>
        </Border>

        <!-- 核心依赖 -->
        <TextBlock Text="核心依赖" Classes="settingSectionHeader" Margin="0,16,0,6" />

        <ListBox ItemsSource="{Binding Dependencies}" BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:DependencyInfo">
              <Border Padding="0,8,0,8" BorderThickness="0,0,0,1"
                      BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}"
                      Background="Transparent">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                  <!-- Row 0: 名称 | 版本 | 许可证 | 链接 -->
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                             FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version}" FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             VerticalAlignment="Center" Margin="8,0,0,0" />
                  <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding License}" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             VerticalAlignment="Center" Margin="8,0,0,0" />
                  <Button Grid.Row="0" Grid.Column="3"
                          Command="{Binding #AboutHost.DataContext.OpenUrlCommand}"
                          CommandParameter="{Binding Url}"
                          AutomationProperties.Name="{Binding Name, StringFormat='打开 {0} 项目页面'}"
                          Classes="depLink"
                          VerticalAlignment="Center" Margin="2,0,0,0">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Link}" FontSize="13"
                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </Button>
                  <!-- Row 1: 用途 -->
                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                             Text="{Binding Purpose}" FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             Margin="0,2,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部链接 -->
        <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="0,16,0,24">
          <Button Command="{Binding OpenUrlCommand}"
                  CommandParameter="{Binding ProjectUrl}"
                  Classes="linkButton"
                  HorizontalContentAlignment="Center">
            <TextBlock Text="{Binding ProjectUrl}" FontSize="12" />
          </Button>
          <TextBlock Text="{Binding Copyright}" FontSize="11"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
