<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:A_Pair.Presentation.Avalonia.ViewModels"
             x:Class="A_Pair.Presentation.Avalonia.Views.PluginManagementView"
             x:DataType="vm:PluginManagementViewModel">

  <Grid Margin="8">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="安装插件..." Command="{Binding InstallPluginCommand}" />
        <Button Content="扫描目录" Command="{Binding ScanCommand}" />
        <Button Content="启用所有" Command="{Binding EnableAllCommand}" />
        <Button Content="禁用所有" Command="{Binding DisableAllCommand}" />
      </StackPanel>
      <DataGrid Items="{Binding Plugins}" SelectedItem="{Binding SelectedPlugin}" AutoGenerateColumns="False" Margin="0,8,0,0">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="60"/>
          <DataGridTextColumn Header="名称" Binding="{Binding Name}" />
          <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100"/>
          <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="100"/>
          <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="80"/>
        </DataGrid.Columns>
      </DataGrid>
    </StackPanel>

    <StackPanel Grid.Column="1" Margin="8">
      <TextBlock Text="插件详情" FontWeight="Bold" />
      <TextBlock Text="{Binding SelectedPlugin.Description}" TextWrapping="Wrap" Margin="0,4,0,8"/>
      <TextBlock Text="脚本文件:" FontWeight="SemiBold"/>
      <TextBlock Text="{Binding SelectedPlugin.ScriptFile}" />
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="编辑脚本" Command="{Binding EditScriptCommand}" />
        <Button Content="重载" Command="{Binding ReloadPluginCommand}" />
      </StackPanel>
      <TextBlock Text="{Binding PluginError}" Foreground="Red" Margin="0,8,0,0"/>
    </StackPanel>
  </Grid>
</UserControl>