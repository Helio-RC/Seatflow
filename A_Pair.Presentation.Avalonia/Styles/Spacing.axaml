<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══ 间距令牌 ═══ -->

  <!-- 页面统一外边距 (DockPanel/Border) -->
  <Style Selector="DockPanel.pageMargin">
    <Setter Property="Margin" Value="16" />
  </Style>
  <Style Selector="Border.pageMargin">
    <Setter Property="Margin" Value="16" />
  </Style>

  <!-- 卡片内边距 -->
  <Style Selector="Border.cardPadding">
    <Setter Property="Padding" Value="20" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <!-- 顶部工具栏外边距 -->
  <Style Selector="Border.toolbarTop">
    <Setter Property="Margin" Value="0,0,0,16" />
  </Style>

  <!-- 底部状态栏外边距 -->
  <Style Selector="Border.statusBarBottom">
    <Setter Property="Padding" Value="0,8,0,0" />
  </Style>

  <!-- 区块间距 -->
  <Style Selector="Border.sectionSpacing">
    <Setter Property="Margin" Value="0,0,0,12" />
  </Style>

  <!-- 通用内边距 8px -->
  <Style Selector="Border.paddingSm">
    <Setter Property="Padding" Value="8" />
  </Style>

  <!-- ═══ 圆角预设 (CornerRadius) ═══ -->

  <Style Selector="Border.radiusXs">
    <Setter Property="CornerRadius" Value="2" />
  </Style>
  <Style Selector="Border.radiusSm">
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Border.radiusMd">
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="Border.radiusLg">
    <Setter Property="CornerRadius" Value="12" />
  </Style>
  <Style Selector="Border.radiusXl">
    <Setter Property="CornerRadius" Value="16" />
  </Style>
  <Style Selector="Border.radiusFull">
    <Setter Property="CornerRadius" Value="9999" />
  </Style>

  <!-- ═══ 阴影预设 (BoxShadow) ═══ -->

  <Style Selector="Border.elevationNone">
    <Setter Property="BoxShadow" Value="{DynamicResource CardShadowNone}" />
  </Style>
  <Style Selector="Border.elevationSm">
    <Setter Property="BoxShadow" Value="{DynamicResource CardShadowSmall}" />
  </Style>
  <Style Selector="Border.elevationMd">
    <Setter Property="BoxShadow" Value="{DynamicResource CardShadowLarge}" />
  </Style>

</Styles>
