<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══ 语义色样式类（用于 Icon / TextBlock 着色） ═══ -->

  <!-- 成功：绿色 -->
  <Style Selector="TextBlock.textSuccess">
    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
  </Style>

  <!-- 警告：橙色 -->
  <Style Selector="TextBlock.textWarning">
    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
  </Style>

  <!-- 错误：红色 -->
  <Style Selector="TextBlock.textError">
    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
  </Style>

  <!-- 信息：蓝色 -->
  <Style Selector="TextBlock.textInfo">
    <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
  </Style>

  <!-- ═══ Surface 样式类 ═══ -->

  <!-- 卡片容器 -->
  <Style Selector="Border.surfaceCard">
    <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

</Styles>
