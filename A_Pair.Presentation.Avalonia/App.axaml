<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="A_Pair.Presentation.Avalonia.App"
             xmlns:local="using:A_Pair.Presentation.Avalonia"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SidebarBackgroundColor">#F0F0F0</Color>
                    <Color x:Key="LoadingOverlayColor">#40FFFFFF</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SidebarBackgroundColor">#252525</Color>
                    <Color x:Key="LoadingOverlayColor">#40000000</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{DynamicResource SidebarBackgroundColor}" />
            <SolidColorBrush x:Key="LoadingOverlayBrush" Color="{DynamicResource LoadingOverlayColor}" />
            <SolidColorBrush x:Key="PreviewSeatBorderBrush" Color="#80FFFFFF" />
            <SolidColorBrush x:Key="PreviewPodiumFillBrush" Color="#4080D0E0" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter,Microsoft YaHei UI,PingFang SC,Noto Sans CJK SC,WenQuanYi Micro Hei,sans-serif"/>
        </Style>
        <FluentTheme />
    </Application.Styles>
</Application>
