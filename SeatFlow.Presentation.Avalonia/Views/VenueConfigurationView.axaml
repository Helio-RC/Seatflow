<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lang="using:SeatFlow.Presentation.Avalonia.Lang"
             xmlns:vm="using:SeatFlow.Presentation.Avalonia.ViewModels"
             xmlns:conv="using:SeatFlow.Presentation.Avalonia.Converters"
             xmlns:behaviors="using:SeatFlow.Presentation.Avalonia.Behaviors"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             x:Class="SeatFlow.Presentation.Avalonia.Views.VenueConfigurationView"
             x:DataType="vm:VenueConfigurationViewModel">

  <DockPanel Classes="pageMargin">
    <!-- 顶部工具栏 -->
    <Border DockPanel.Dock="Top" Classes="toolbarTop">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.Venue_Title}" Classes="pageTitle" 
                   VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Command="{Binding DeleteVenueCommand}"
                  IsEnabled="{Binding HasSelectedVenue}"
                  AutomationProperties.Name="{x:Static lang:Resources.Venue_DeleteVenue}"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Delete}" FontSize="16" />
              <TextBlock Text="{x:Static lang:Resources.Common_Delete}" FontSize="14" />
            </StackPanel>
          </Button>
          <Button x:Name="SaveVenueButton" Command="{Binding SaveVenueCommand}"
                  IsEnabled="{Binding HasSelectedVenue}"
                  AutomationProperties.Name="{x:Static lang:Resources.Venue_SaveVenue}"
                  HorizontalContentAlignment="Center" Classes="accent">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Save}" FontSize="16" />
              <TextBlock Text="{x:Static lang:Resources.Common_Save}" FontSize="14" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 底部状态栏 -->
    <Border DockPanel.Dock="Bottom" Classes="statusBarBottom">
      <TextBlock Text="{Binding StatusMessage}" Classes="caption"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
    </Border>

    <!-- 中间内容区 -->
    <Grid x:Name="SidebarGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <!-- 左侧：会场列表 -->
      <Border Grid.Column="0" Width="{Binding SidebarListWidth}" Margin="0,0,8,0" CornerRadius="6"
              ClipToBounds="True" HorizontalAlignment="Left"
              Background="{DynamicResource SidebarBackgroundBrush}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.25" Easing="CubicEaseInOut" />
          </Transitions>
        </Border.Transitions>
        <DockPanel Margin="8">
          <TextBlock DockPanel.Dock="Top" Text="{x:Static lang:Resources.Venue_List}"
                     FontSize="14" FontWeight="SemiBold" Margin="3,0,0,8" />
          <Border DockPanel.Dock="Bottom">
            <Panel>
              <!-- 展开状态 -->
              <Border>
                <Border.Transitions>
                  <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseInOut" />
                  </Transitions>
                </Border.Transitions>
                <StackPanel Margin="10,0,10,4" Spacing="8" Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.TrueToVisible}}"
                            IsHitTestVisible="{Binding IsSidebarExpanded}" HorizontalAlignment="Left">
                  <Button Command="{Binding LoadVenueListCommand}" CommandParameter="MemberManagement"
                          HorizontalContentAlignment="Left" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                      <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowSync}" FontSize="20" Height="20"/>
                      <TextBlock Text="{x:Static lang:Resources.Venue_Refresh}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="NewVenueButton" Command="{Binding NewVenueCommand}" CommandParameter="VenueConfiguration"
                          AutomationProperties.Name="{x:Static lang:Resources.Venue_New}"
                          HorizontalContentAlignment="Left" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                      <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Add}" FontSize="20" Height="20"/>
                      <TextBlock Text="{x:Static lang:Resources.Venue_New}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding ToggleSidebarCommand}"
                          HorizontalContentAlignment="Left" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                      <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftContract}" FontSize="20" Height="20"/>
                      <TextBlock Text="{x:Static lang:Resources.Nav_CollapseSidebar}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Border>

              <!-- 折叠状态 -->
              <Border>
                <Border.Transitions>
                  <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut" />
                  </Transitions>
                </Border.Transitions>
                <StackPanel Margin="10,0,10,4" Spacing="8" Opacity="{Binding IsSidebarExpanded, Converter={x:Static conv:BoolConverters.FalseToVisible}}"
                            IsHitTestVisible="{Binding IsSidebarCollapsed}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                  <StackPanel.Transitions>
                    <Transitions>
                      <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="SineEaseInOut" />
                    </Transitions>
                  </StackPanel.Transitions>
                  <Button HorizontalContentAlignment="Left"
                          Command="{Binding LoadVenueListCommand}"
                          ToolTip.Tip="{x:Static lang:Resources.Venue_Refresh}">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowSync}" FontSize="20" Height="20"/>
                  </Button>
                  <Button HorizontalContentAlignment="Left"
                          Command="{Binding NewVenueCommand}"
                          ToolTip.Tip="{x:Static lang:Resources.Venue_New}">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Add}" FontSize="20" Height="20"/>
                  </Button>
                  <Button HorizontalContentAlignment="Left"
                          Command="{Binding ToggleSidebarCommand}"
                          ToolTip.Tip="{x:Static lang:Resources.Venue_ExpandList}">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.PanelLeftExpand}" FontSize="20" Height="20"/>
                  </Button>
                </StackPanel>
              </Border>
            </Panel>
          </Border>
          <ListBox DockPanel.Dock="Bottom" ItemsSource="{Binding VenueItems}"
                   SelectedItem="{Binding SelectedVenueItem, Mode=TwoWay}"
                   BorderThickness="0" Background="{DynamicResource SidebarBackgroundBrush}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VenueItem">
                <TextBlock Text="{Binding Name}" FontSize="13" Margin="4,6"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- 分隔条 -->
      <GridSplitter Grid.Column="1" Width="4" Background="Transparent" IsEnabled="False" IsVisible="False"
                    HorizontalAlignment="Stretch" />

      <!-- 右侧 -->
      <Grid Grid.Column="2">
        <!-- 空状态提示 -->
        <Border IsVisible="{Binding HasSelectedVenue, Converter={x:Static conv:BoolConverters.Negate}}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Padding="40" CornerRadius="8">
          <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Building}" FontSize="48"
                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            HorizontalAlignment="Center" />
            <TextBlock Text="{x:Static lang:Resources.Venue_NoSelection}" Classes="sectionTitle"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Text="{x:Static lang:Resources.Venue_SelectHint}"
                       FontSize="12" HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </StackPanel>
        </Border>

        <!-- 布局编辑器 -->
        <ScrollViewer IsVisible="{Binding HasSelectedVenue}">
          <DockPanel Margin="16,0">
            <!-- 名称和类型区 -->
            <StackPanel DockPanel.Dock="Top" Spacing="12" Classes="toolbarTop">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_Name}" FontSize="13" VerticalAlignment="Center"/>
                <TextBox Text="{Binding LayoutName, Mode=TwoWay}" Width="200" FontSize="14"/>
              </StackPanel>
              <StackPanel x:Name="LayoutTypePanel" Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_LayoutType}" FontSize="14" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <RadioButton GroupName="LayoutType" IsChecked="{Binding IsGridSelected, Mode=OneWay}"
                               IsEnabled="{Binding CanChangeLayoutType}"
                               Command="{Binding SelectLayoutTypeCommand}" CommandParameter="Grid"
                               Content="{x:Static lang:Resources.Venue_GridType}"/>
                  <RadioButton GroupName="LayoutType" IsChecked="{Binding IsPolarSelected, Mode=OneWay}"
                               IsEnabled="{Binding CanChangeLayoutType}"
                               Command="{Binding SelectLayoutTypeCommand}" CommandParameter="Polar"
                               Content="{x:Static lang:Resources.Venue_PolarType}"/>
                  <RadioButton GroupName="LayoutType" IsChecked="{Binding IsFreeformSelected, Mode=OneWay}"
                               IsEnabled="{Binding CanChangeLayoutType}"
                               Command="{Binding SelectLayoutTypeCommand}" CommandParameter="Freeform"
                               Content="{x:Static lang:Resources.Venue_FreeformType}"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <!-- Grid 基础参数面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsGridSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_BasicParams}" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_Rows}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding GridRows, Mode=TwoWay}"
                                 Minimum="1" Maximum="100"
                                 PlaceholderText="{x:Static lang:Resources.Venue_RowsPH}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_RowsTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_Cols}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="3" Grid.Row="0" Value="{Binding GridColumns, Mode=TwoWay}"
                                 Minimum="1" Maximum="100"
                                 PlaceholderText="{x:Static lang:Resources.Venue_ColsPH}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_ColsTooltip}"/>

                  <TextBlock Grid.Column="0" Grid.Row="1" Text="{x:Static lang:Resources.Venue_HSpacing}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="1" Value="{Binding GridHorizontalSpacing, Mode=TwoWay}"
                                 Minimum="4" Maximum="600"
                                 PlaceholderText="{x:Static lang:Resources.Venue_HSpacingPH}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_HSpacingTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="1" Text="{x:Static lang:Resources.Venue_VSpacing}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="3" Grid.Row="1" Value="{Binding GridVerticalSpacing, Mode=TwoWay}"
                                 Minimum="4" Maximum="600"
                                 PlaceholderText="{x:Static lang:Resources.Venue_VSpacingPH}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_VSpacingTooltip}"/>

                  <TextBlock Grid.Column="0" Grid.Row="2" Text="{x:Static lang:Resources.Venue_OriginX}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="2" Value="{Binding GridOriginX, Mode=TwoWay}"
                                 Minimum="0" Maximum="2000"
                                 PlaceholderText="{x:Static lang:Resources.Venue_OriginXPH}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_OriginXTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="2" Text="{x:Static lang:Resources.Venue_OriginY}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="3" Grid.Row="2" Value="{Binding GridOriginY, Mode=TwoWay}"
                                 Minimum="0" Maximum="2000"
                                 PlaceholderText="{x:Static lang:Resources.Venue_OriginYPH}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_OriginYTooltip}"/>
                </Grid>

                <!-- 可选配置分隔条 -->
                <Border BorderThickness="0,1,0,0" Padding="0,4,0,0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                  <TextBlock Text="{x:Static lang:Resources.Venue_Optional}" FontSize="11" Opacity="0.5"/>
                </Border>

                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_ColumnRowCounts}" VerticalAlignment="Center" FontSize="13"/>
                  <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding GridColumnRowCountsSpec, Mode=TwoWay}"
                           FontSize="13" PlaceholderText="{x:Static lang:Resources.Venue_DefaultColumnRowCounts}"
                           ToolTip.Tip="{x:Static lang:Resources.Venue_ColumnRowCountsTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_DisabledSeats}" VerticalAlignment="Center" FontSize="13"/>
                  <TextBox Grid.Column="3" Grid.Row="0" Text="{Binding GridEmptyPositionsSpec, Mode=TwoWay}"
                           FontSize="13" PlaceholderText="{x:Static lang:Resources.Venue_DisabledSeatsPH}"
                           ToolTip.Tip="{x:Static lang:Resources.Venue_DisabledSeatsTooltip}"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Grid 桌面配置面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsGridSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_DeskConfig}" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_DeskSize}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding GridSeatsPerDesk, Mode=TwoWay}"
                                 Minimum="1" Maximum="6"
                                 PlaceholderText="2"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_DeskSizeTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_DeskInnerSpacing}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="3" Grid.Row="0" Value="{Binding GridIntraDeskSpacing, Mode=TwoWay}"
                                 Minimum="4" Maximum="200"
                                 PlaceholderText="12 px"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_DeskInnerSpacingTooltip}"/>
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_DeskSpacing}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding GridInterDeskSpacing, Mode=TwoWay}"
                                 Minimum="4" Maximum="400"
                                 PlaceholderText="40 px"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_DeskSpacingTooltip}"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Grid 过道配置面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsGridSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_AisleConfig}" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static lang:Resources.Venue_ColumnAisles}" Classes="caption"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <ItemsControl ItemsSource="{Binding AisleColumnOptions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AisleOption">
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Content="{Binding Label}"
                                FontSize="12" Margin="0,0,12,4"
                                ToolTip.Tip="{x:Static lang:Resources.Venue_AisleCheckTooltip}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{x:Static lang:Resources.Venue_RowAisles}" FontSize="12" Margin="0,8,0,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <ItemsControl ItemsSource="{Binding AisleRowOptions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AisleOption">
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Content="{Binding Label}"
                                FontSize="12" Margin="0,0,12,4"
                                ToolTip.Tip="{x:Static lang:Resources.Venue_AisleCheckTooltip}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                  <TextBlock Text="{x:Static lang:Resources.Venue_AisleWidth}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Value="{Binding GridAisleWidth, Mode=TwoWay}"
                                 Minimum="12" Maximum="300"
                                 PlaceholderText="60 px"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_AisleWidthTooltip}"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Grid 教室特征面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsGridSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_ClassroomFeatures}" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_FrontRows}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding GridFrontRowCount, Mode=TwoWay}"
                                 Minimum="1" Maximum="10"
                                 PlaceholderText="1"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_FrontRowsTooltip}"/>

                  <CheckBox Grid.Column="2" Grid.Row="0" Grid.ColumnSpan="2"
                            IsChecked="{Binding GridHasPodium, Mode=TwoWay}"
                            Content="{x:Static lang:Resources.Venue_HasPodium}" FontSize="13"
                            ToolTip.Tip="{x:Static lang:Resources.Venue_HasPodiumTooltip}"/>
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left"
                      IsVisible="{Binding GridHasPodium}">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_PodiumWidth}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding GridPodiumWidth, Mode=TwoWay}"
                                 Minimum="20" Maximum="400"
                                 PlaceholderText="60 px"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_PodiumWidthTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_PodiumHeight}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding GridPodiumHeight, Mode=TwoWay}"
                                 Minimum="20" Maximum="200"
                                 PlaceholderText="40 px"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_PodiumHeightTooltip}"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Polar 基础参数面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsPolarSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_BasicParams}" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_Rings}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding PolarRings, Mode=TwoWay}"
                                 Minimum="1" Maximum="20"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_RingsTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_SeatsPerRing}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding PolarSeatsPerRing, Mode=TwoWay}"
                                 Minimum="2" Maximum="120"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_SeatsPerRingTooltip}"/>

                  <TextBlock Grid.Column="0" Grid.Row="1" Text="{x:Static lang:Resources.Venue_RadiusStep}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="1" Value="{Binding PolarRadiusStep, Mode=TwoWay}"
                                 Minimum="8" Maximum="400"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_RadiusStepTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="1" Text="{x:Static lang:Resources.Venue_StartAngle}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding PolarStartAngle, Mode=TwoWay}"
                                 Minimum="0" Maximum="360"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_StartAngleTooltip}"/>

                  <TextBlock Grid.Column="0" Grid.Row="2" Text="{x:Static lang:Resources.Venue_EndAngle}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="2" Value="{Binding PolarEndAngle, Mode=TwoWay}"
                                 Minimum="10" Maximum="360"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_EndAngleTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="2" Text="{x:Static lang:Resources.Venue_OriginX}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Row="2" Grid.Column="3" Value="{Binding PolarOriginX, Mode=TwoWay}"
                                 Minimum="0" Maximum="2000"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_PolarOriginXTooltip}"/>
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_OriginY}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding PolarOriginY, Mode=TwoWay}"
                                 Minimum="0" Maximum="2000"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_PolarOriginYTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_RingSeats}" VerticalAlignment="Center" FontSize="13"/>
                  <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding PolarRingSeatCountsSpec, Mode=TwoWay}"
                           FontSize="13" PlaceholderText="{x:Static lang:Resources.Venue_RingSeatsPH}"
                           ToolTip.Tip="{x:Static lang:Resources.Venue_RingSeatsTooltip}"/>
                </Grid>

                <!-- 可选配置分隔条 -->
                <Border BorderThickness="0,1,0,0" Padding="0,4,0,0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                  <TextBlock Text="{x:Static lang:Resources.Venue_Optional}" FontSize="11" Opacity="0.5"/>
                </Border>

                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_DisabledSeats}" VerticalAlignment="Center" FontSize="13"/>
                  <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding PolarEmptyPositionsSpec, Mode=TwoWay}"
                           FontSize="13" PlaceholderText="{x:Static lang:Resources.Venue_PolarDisabledPH}"
                           ToolTip.Tip="{x:Static lang:Resources.Venue_PolarDisabledTooltip}"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Polar 教室特征面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsPolarSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_ClassroomFeatures}" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_FrontRows}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="0" Value="{Binding PolarFrontRowCount, Mode=TwoWay}"
                                 Minimum="1" Maximum="10"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_PolarFrontRowsTooltip}"/>

                  <CheckBox Grid.Column="2" Grid.Row="0" Grid.ColumnSpan="2"
                            IsChecked="{Binding PolarHasPodium, Mode=TwoWay}"
                            Content="{x:Static lang:Resources.Venue_HasPodium}" FontSize="13"/>

                  <TextBlock Grid.Column="0" Grid.Row="1" Text="{x:Static lang:Resources.Venue_PodiumRadius}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Column="1" Grid.Row="1" Value="{Binding PolarPodiumRadius, Mode=TwoWay}"
                                 Minimum="10" Maximum="200" IsEnabled="{Binding PolarHasPodium}"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_PodiumRadiusTooltip}"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Polar 通道配置面板 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsPolarSelected}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_ChannelConfig}" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto"
                      RowSpacing="6" ColumnSpacing="12"
                      HorizontalAlignment="Left">
                  <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static lang:Resources.Venue_RadialAisleAngles}" VerticalAlignment="Center" FontSize="13"/>
                  <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding PolarAisleRadialAngles, Mode=TwoWay}"
                           FontSize="13" PlaceholderText="{x:Static lang:Resources.Venue_RadialAislePH}"
                           ToolTip.Tip="{x:Static lang:Resources.Venue_RadialAisleAnglesTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="0" Text="{x:Static lang:Resources.Venue_RadialAisleWidth}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding PolarAisleRadialWidth, Mode=TwoWay}"
                                 Minimum="1" Maximum="30"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_RadialAisleWidthTooltip}"/>

                  <TextBlock Grid.Column="0" Grid.Row="1" Text="{x:Static lang:Resources.Venue_RingAislePositions}" VerticalAlignment="Center" FontSize="13"/>
                  <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding PolarAisleCircularRings, Mode=TwoWay}"
                           FontSize="13" PlaceholderText="{x:Static lang:Resources.Venue_RingAislePH}"
                           ToolTip.Tip="{x:Static lang:Resources.Venue_RingAislePositionsTooltip}"/>
                  <TextBlock Grid.Column="2" Grid.Row="1" Text="{x:Static lang:Resources.Venue_RingAisleWidth}" VerticalAlignment="Center" FontSize="13"/>
                  <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding PolarAisleCircularWidth, Mode=TwoWay}"
                                 Minimum="4" Maximum="200"
                                 ToolTip.Tip="{x:Static lang:Resources.Venue_RingAisleWidthTooltip}"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- 门配置面板（Grid + Polar 共用） -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsDoorPanelVisible}"
                    Padding="12" Margin="0,0,0,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Classes="radiusSm">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{x:Static lang:Resources.Venue_DoorSection}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <Button Command="{Binding AddDoorCommand}" Padding="8,2" Classes="caption"
                          ToolTip.Tip="{x:Static lang:Resources.Venue_AddDoorTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Add}" FontSize="14"/>
                      <TextBlock Text="{x:Static lang:Resources.Venue_AddDoor}" FontSize="12"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding DoorItems}" HorizontalAlignment="Stretch">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DoorItem">
                      <Border Padding="4,2" BorderThickness="0,0,0,1" HorizontalAlignment="Stretch"
                              BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto" HorizontalAlignment="Left" VerticalAlignment="Center"
                              RowSpacing="8" ColumnSpacing="16">
                          <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding Label}" Classes="caption"
                                     VerticalAlignment="Center" Margin="0,0,8,0" HorizontalAlignment="Left"/>
                          <StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="1">
                            <TextBlock Text="X :" FontSize="12" VerticalAlignment="Center"/>
                            <NumericUpDown Value="{Binding X, Mode=TwoWay}"
                                           Minimum="0" Maximum="2000" Classes="caption"
                                           ToolTip.Tip="{x:Static lang:Resources.Venue_DoorXTooltip}"/>
                            <TextBlock Text="Y :" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" HorizontalAlignment="Right"/>
                            <NumericUpDown Value="{Binding Y, Mode=TwoWay}"
                                           Minimum="0" Maximum="2000" Classes="caption"
                                           ToolTip.Tip="{x:Static lang:Resources.Venue_DoorYTooltip}"/>
                          </StackPanel>
                          <Button Grid.Row="0" Grid.Column="3" Command="{Binding $parent[UserControl].DataContext.RemoveDoorCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="4" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Delete}" FontSize="14"/>
                          </Button>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Freeform 提示 -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding IsFreeformSelected}"
                    Padding="12" Classes="toolbarTop radiusSm"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
              <StackPanel Spacing="8">
                <TextBlock Text="{x:Static lang:Resources.Venue_FreeformHint}"
                           FontSize="13" TextWrapping="Wrap"/>
                <Button Command="{Binding NavigateToFreeformCommand}"
                        HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                        Padding="8,4" FontSize="12">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowMove}" FontSize="14"/>
                    <TextBlock Text="{x:Static lang:Resources.Venue_OpenFreeform}" FontSize="12"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>

            <!-- 预览区域 -->
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{x:Static lang:Resources.Venue_Preview}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Command="{Binding RegeneratePreviewCommand}"
                        HorizontalContentAlignment="Center" Padding="8,4" FontSize="12">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.ArrowSync}" FontSize="14"/>
                    <TextBlock Text="{x:Static lang:Resources.Venue_RefreshPreview}" FontSize="12"/>
                  </StackPanel>
                </Button>
              </StackPanel>

              <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                      Classes="radiusSm" MinHeight="300" Padding="8">
                <Grid>
                  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                Background="{DynamicResource PreviewBackgroundBrush}"
                                behaviors:CanvasZoomPan.Enabled="True">
                    <Grid>
                      <!-- 座位层 -->
                      <ItemsControl ItemsSource="{Binding PreviewSeats}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <Canvas Width="{Binding $parent[UserControl].DataContext.CanvasWidth, Mode=OneWay}" Height="{Binding $parent[UserControl].DataContext.CanvasHeight, Mode=OneWay}"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                          <Style Selector="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{ReflectionBinding X}"/>
                            <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}"/>
                          </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SeatPreview">
                            <Border Width="{ReflectionBinding Width}" Height="{ReflectionBinding Height}"
                                    CornerRadius="{ReflectionBinding CornerRadius}"
                                    BorderThickness="{ReflectionBinding BorderThickness}"
                                    BorderBrush="{StaticResource PreviewSeatBorderBrush}"
                                    ToolTip.Tip="{Binding Label}">
                              <Border.Background>
                                <SolidColorBrush Color="{DynamicResource SystemAccentColor}"/>
                              </Border.Background>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <!-- 覆盖层: 讲台/障碍物/门 -->
                      <ItemsControl ItemsSource="{Binding PreviewOverlays}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <Canvas Width="{Binding $parent[UserControl].DataContext.CanvasWidth, Mode=OneWay}" Height="{Binding $parent[UserControl].DataContext.CanvasHeight, Mode=OneWay}"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                          <Style Selector="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{ReflectionBinding X}"/>
                            <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}"/>
                          </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SeatPreview">
                            <Panel Width="{ReflectionBinding Width}" Height="{ReflectionBinding Height}"
                                   RenderTransformOrigin="0,0"
                                   ToolTip.Tip="{Binding Label}">
                              <Border CornerRadius="1000"
                                      BorderThickness="{ReflectionBinding BorderThickness}"
                                      Background="{ReflectionBinding BackgroundColor}"
                                      BorderBrush="{ReflectionBinding BorderColor}"
                                      Opacity="0.7"/>
                              <Path Data="{ReflectionBinding PathGeometry}"
                                    Fill="{StaticResource PreviewPodiumFillBrush}"
                                    Opacity="0.7"/>
                              <TextBlock Text="{Binding Label}" FontSize="11"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                              <Panel.RenderTransform>
                                <RotateTransform Angle="{ReflectionBinding Rotation}"/>
                              </Panel.RenderTransform>
                            </Panel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </ScrollViewer>
                  <TextBlock Text="{x:Static lang:Resources.Venue_DragHint}" FontSize="11" Opacity="0.4"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,12,8"/>
                </Grid>
              </Border>
            </StackPanel>
          </DockPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
