<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SeatFlow.Presentation.Avalonia.ViewModels"
             xmlns:fic="using:FluentIcons.Avalonia"
             xmlns:ficEnum="clr-namespace:FluentIcons.Common;assembly=FluentIcons.Common"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:lang="using:SeatFlow.Presentation.Avalonia.Lang"
             x:Class="SeatFlow.Presentation.Avalonia.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             x:Name="AboutHost">

  <Design.DataContext>
    <vm:AboutViewModel />
  </Design.DataContext>

  <DockPanel Margin="16">
    <!-- 顶部标题 -->
    <Border DockPanel.Dock="Top" Margin="0,0,0,24">
      <TextBlock Text="{x:Static lang:Resources.About_Title}" Classes="pageTitle" VerticalAlignment="Center" />
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0" MaxWidth="520" HorizontalAlignment="Center">

        <!-- 应用信息头部 -->
        <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,8,0,0">
          <svg:Svg Path="/Assets/icon_with_background.svg"
                   Width="240" Height="240"
                   HorizontalAlignment="Center"
                   Stretch="Uniform" />
          <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold"
                     HorizontalAlignment="Center" />
          <TextBlock HorizontalAlignment="Center" FontSize="13"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     Text="{Binding VersionDisplay}" />
        </StackPanel>

        <!-- 描述 -->
        <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap"
                   HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   Margin="0,12,0,0" />

        <!-- MIT 许可证警告横幅 -->
        <Border Classes="bgError" Padding="10" CornerRadius="4" Margin="0,12,0,0">
          <StackPanel Spacing="4">
            <TextBlock Text="{x:Static lang:Resources.About_MITLicenseWarning}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Separator Margin="0,12,0,8" />

        <!-- 运行环境 -->
        <TextBlock Text="{x:Static lang:Resources.About_Runtime}" Classes="settingSectionHeader" Margin="0,8,0,6" />

        <Border Classes="settingRow">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.About_Framework}" Classes="body"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding RuntimeVersion}" Classes="body"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </DockPanel>
        </Border>

        <Border Classes="settingRow">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.About_Avalonia}" Classes="body"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding AvaloniaVersion}" Classes="body"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </DockPanel>
        </Border>

        <Border Classes="settingRow" BorderThickness="0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="{x:Static lang:Resources.About_License}" Classes="body"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding License}" Classes="body"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </DockPanel>
        </Border>

        <!-- 核心依赖 -->
        <TextBlock Text="{x:Static lang:Resources.About_Dependencies}" Classes="settingSectionHeader" Margin="0,16,0,6" />

        <ListBox ItemsSource="{Binding Dependencies}" BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:DependencyInfo">
              <Border Padding="0,8,0,8" BorderThickness="0,0,0,1"
                      BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}"
                      Background="Transparent">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                  <!-- Row 0: 名称 | 版本 | 许可证 | 链接 -->
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                             FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version}" FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             VerticalAlignment="Center" Margin="8,0,0,0" />
                  <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding License}" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             VerticalAlignment="Center" Margin="8,0,0,0" />
                  <Button Grid.Row="0" Grid.Column="3"
                          Command="{Binding #AboutHost.DataContext.OpenUrlCommand}"
                          CommandParameter="{Binding Url}"
                          AutomationProperties.Name="{Binding Name}"
                          Classes="depLink"
                          VerticalAlignment="Center" Margin="2,0,0,0">
                    <fic:FluentIcon Icon="{x:Static ficEnum:Icon.Link}" FontSize="13"
                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </Button>
                  <!-- Row 1: 用途 -->
                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                             Text="{Binding Purpose}" FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             Margin="0,2,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部链接 -->
        <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="0,16,0,24">
          <Button Command="{Binding OpenUrlCommand}"
                  CommandParameter="{Binding ProjectUrl}"
                  Classes="linkButton"
                  HorizontalContentAlignment="Center">
            <TextBlock Text="{Binding ProjectUrl}" FontSize="12" />
          </Button>
          <TextBlock Text="{Binding Copyright}" FontSize="11"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
